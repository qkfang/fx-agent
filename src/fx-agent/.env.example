# Azure AI Foundry connection string (required for live agent mode)
# Format: "endpoint=https://...;subscription_id=...;resource_group=...;project_name=..."
AZURE_AI_CONNECTION_STRING=

# Azure OpenAI model deployment name in your Foundry project
AZURE_AI_MODEL=gpt-4o

# Base URLs of the existing .NET services
BROKER_BACKOFFICE_URL=http://localhost:5001
TRADING_PLATFORM_URL=http://localhost:5000
NEWS_FEED_URL=http://localhost:5002
