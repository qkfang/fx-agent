@page
@model IndexModel
@{
    ViewData["Title"] = "Trading Platform";
    var initialRate = Model.CurrentRate?.Rate ?? 0.6550m;
}

<!-- View Tabs -->
<div class="view-tabs">
    <button class="view-tab-btn active" id="btnSimple" onclick="switchView('simple')">Simple</button>
    <button class="view-tab-btn" id="btnAdvanced" onclick="switchView('advanced')">Advanced</button>
    <button class="view-tab-btn" id="btnBlotter" onclick="switchView('blotter')">Aurora</button>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     SIMPLE VIEW  (existing dashboard – unchanged)
     ═══════════════════════════════════════════════════════════════ -->
<div id="simpleView">

    <!-- Live Price Ticker -->
    <div class="price-ticker">
        <span class="ticker-pair">AUD/USD</span>
        <span class="ticker-price" id="livePrice">@initialRate.ToString("F4")</span>
        <span class="ticker-change up" id="priceChange">&#9650; +0.0000 (+0.00%)</span>
        <div class="ticker-meta">
            <span>High <strong id="sessionHigh">@initialRate.ToString("F4")</strong></span>
            <span>Low <strong id="sessionLow">@initialRate.ToString("F4")</strong></span>
            <span>Spread <strong id="spread">0.0002</strong></span>
            <span>Trades <strong id="tradeCount">@(Model.Transactions?.Count ?? 0)</strong></span>
        </div>
    </div>

    <!-- Real-time Chart -->
    <div class="card mb-3 mt-3">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span class="section-title">AUD/USD &mdash; Live Chart</span>
            <span class="text-success small"><span class="live-dot me-1">&#9679;</span>Real-time</span>
        </div>
        <div class="card-body p-2">
            <div class="chart-wrapper">
                <canvas id="forexChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Fund Summary -->
    <div class="card mb-3">
        <div class="card-header">
            <span class="section-title">Fund Summary</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="fund-label">Total Balance</div>
                    <div class="fund-value accent">$@Model.FundSummary?.TotalBalance.ToString("N2")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fund-label">AUD Balance</div>
                    <div class="fund-value">$@Model.FundSummary?.AudBalance.ToString("N2")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fund-label">USD Balance</div>
                    <div class="fund-value">$@Model.FundSummary?.UsdBalance.ToString("N2")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="fund-label">Total P&amp;L</div>
                    <div class="fund-value @(Model.FundSummary?.TotalProfitLoss >= 0 ? "positive" : "negative")">
                        $@Model.FundSummary?.TotalProfitLoss.ToString("N2")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Buy & Sell Activity -->
    <div class="card">
        <div class="card-header">
            <span class="section-title">Buy &amp; Sell Activity</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Type</th>
                            <th>Pair</th>
                            <th>Amount</th>
                            <th>Rate</th>
                            <th>Total</th>
                            <th>Date / Time</th>
                        </tr>
                    </thead>
                    <tbody id="tradeTableBody">
                        @if (Model.Transactions != null)
                        {
                            foreach (var transaction in Model.Transactions)
                            {
                                <tr>
                                    <td>@transaction.Id</td>
                                    <td>
                                        <span class="badge @(transaction.Type == "Buy" ? "badge-buy" : "badge-sell")">
                                            @transaction.Type
                                        </span>
                                    </td>
                                    <td>@transaction.CurrencyPair</td>
                                    <td>$@transaction.Amount.ToString("N2")</td>
                                    <td>@transaction.Rate.ToString("F4")</td>
                                    <td>$@transaction.Total.ToString("N2")</td>
                                    <td>@transaction.DateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div><!-- /simpleView -->

<!-- ═══════════════════════════════════════════════════════════════
     ADVANCED VIEW  (TradingView-style candlestick chart)
     ═══════════════════════════════════════════════════════════════ -->
<div id="advancedView" style="display:none">

    <!-- Header row: pair · timeframe · OHLC -->
    <div class="adv-header">
        <div class="adv-header-left">
            <span class="adv-pair">AUD/USD</span>
            <span class="adv-tf" id="advTfLabel">1m · Real-time Currencies</span>
            <span class="adv-ohlc">
                O&nbsp;<span class="ohlc-o" id="advO">&mdash;</span>&nbsp;
                H&nbsp;<span class="ohlc-h" id="advH">&mdash;</span>&nbsp;
                L&nbsp;<span class="ohlc-l" id="advL">&mdash;</span>&nbsp;
                C&nbsp;<span class="ohlc-c" id="advC">&mdash;</span>
            </span>
        </div>
        <div class="adv-header-right">
            <span class="text-success"><span class="live-dot me-1">&#9679;</span>Live</span>
        </div>
    </div>

    <!-- Canvas chart -->
    <div id="advChartContainer">
        <canvas id="advCanvas"></canvas>
    </div>

    <!-- Timeframe toolbar -->
    <div class="adv-toolbar">
        <button class="tf-btn active" data-tf="1"    data-label="1m">1m</button>
        <button class="tf-btn"        data-tf="5"    data-label="5m">5m</button>
        <button class="tf-btn"        data-tf="15"   data-label="15m">15m</button>
        <button class="tf-btn"        data-tf="60"   data-label="1h">1h</button>
        <button class="tf-btn"        data-tf="240"  data-label="4h">4h</button>
        <button class="tf-btn"        data-tf="1440" data-label="1d">1d</button>
    </div>

</div><!-- /advancedView -->

<!-- ═══════════════════════════════════════════════════════════════
     BLOTTER / AURORA VIEW
     ═══════════════════════════════════════════════════════════════ -->
<div id="blotterView" style="display:none">

    <!-- Prices header bar -->
    <div class="fx-prices-bar">
        <span class="fx-prices-label">Prices</span>
        <span class="fx-prices-section">Foreign Exchange</span>
        <button class="fx-add-ccy" onclick="addCcyPrompt()">ADD CCY +</button>
    </div>

    <!-- FX price tiles -->
    <div class="fx-tiles-grid" id="fxTilesGrid"></div>

    <!-- Order ticket modal (fixed overlay) -->
    <div class="order-overlay" id="orderOverlay" style="display:none">
        <div class="order-ticket">
            <div class="ot-header">
                <div class="ot-header-pair">
                    <span class="ot-title">Order Ticket</span>
                    <span class="ot-pair" id="otPairLabel">EUR/USD</span>
                </div>
                <button class="ot-close" onclick="closeOrderTicket()">&times;</button>
            </div>
            <div class="ot-body">
                <div class="ot-row">
                    <span class="ot-lbl">Order Type</span>
                    <div class="ot-ctrl">
                        <select class="ot-select" id="otOrderType">
                            <option>LIMIT</option>
                            <option>MARKET</option>
                            <option>STOP</option>
                        </select>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Direction</span>
                    <div class="ot-ctrl">
                        <div class="ot-toggle">
                            <button class="ot-tog active-buy" id="otBuyBtn" onclick="setDirection('BUY')">BUY</button>
                            <button class="ot-tog" id="otSellBtn" onclick="setDirection('SELL')">SELL</button>
                        </div>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Currency</span>
                    <div class="ot-ctrl">
                        <div class="ot-toggle" id="otCcyToggle"></div>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Qty</span>
                    <div class="ot-input-grp">
                        <button class="ot-step" onclick="stepQty(-1000000)">&#8722;</button>
                        <input class="ot-input" id="otQty" type="text" value="1,000,000.00" />
                        <button class="ot-step" onclick="stepQty(1000000)">+</button>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Limit Price</span>
                    <div class="ot-input-grp">
                        <button class="ot-step" onclick="stepPrice(-0.0001)">&#8722;</button>
                        <input class="ot-input" id="otLimitPrice" type="text" value="0.0000" />
                        <button class="ot-step" onclick="stepPrice(0.0001)">+</button>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Mkt Price</span>
                    <div class="ot-ctrl ot-mkt-row">
                        <span id="otMktPrice">0.0000</span>
                        <span class="ot-mkt-pips" id="otMktPips"></span>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Account</span>
                    <div class="ot-ctrl">
                        <select class="ot-select">
                            <option>PROP-01</option>
                            <option>CLIENT-A</option>
                            <option>CLIENT-B</option>
                        </select>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Pdt Type</span>
                    <div class="ot-ctrl">
                        <select class="ot-select">
                            <option>SPOT</option>
                            <option>FORWARD</option>
                            <option>SWAP</option>
                        </select>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Time In Force</span>
                    <div class="ot-ctrl">
                        <select class="ot-select">
                            <option>GTC</option>
                            <option>DAY</option>
                            <option>IOC</option>
                        </select>
                    </div>
                </div>
                <div class="ot-row">
                    <span class="ot-lbl">Additional Text</span>
                    <div class="ot-ctrl">
                        <input class="ot-input" type="text" placeholder="Optional notes" style="width:100%" />
                    </div>
                </div>
            </div>
            <div class="ot-footer">
                <button class="ot-btn-reset"  onclick="resetOrderTicket()">&#8635; RESET</button>
                <button class="ot-btn-clone"  onclick="cloneOrder()">&#10697; CLONE</button>
                <button class="ot-btn-submit" onclick="submitOrder()">&#10003; SUBMIT</button>
            </div>
        </div>
    </div>

    <!-- Blotter -->
    <div class="blotter-section">
        <div class="blotter-bar">Blotter</div>
        <div class="table-responsive">
            <table class="blotter-tbl" id="blotterTbl">
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Last Updated</th>
                        <th>Status</th>
                        <th>Order Type</th>
                        <th>Account Code</th>
                        <th>Product Type</th>
                        <th>Security</th>
                        <th>Side</th>
                        <th>Currency</th>
                        <th>Qty</th>
                        <th>Cum Qty</th>
                        <th>Avg Px</th>
                        <th>TIF</th>
                        <th>Contra</th>
                    </tr>
                </thead>
                <tbody id="blotterTbody"></tbody>
            </table>
        </div>
    </div>

</div><!-- /blotterView -->

@section Scripts {
<script>
// ============================================================================
//  VIEW SWITCHING
// ============================================================================
var advancedChartInitialized = false;
var blotterInitialized = false;

function switchView(view) {
    var isSimple   = (view === 'simple');
    var isAdvanced = (view === 'advanced');
    var isBlotter  = (view === 'blotter');
    document.getElementById('simpleView').style.display    = isSimple   ? '' : 'none';
    document.getElementById('advancedView').style.display  = isAdvanced ? '' : 'none';
    document.getElementById('blotterView').style.display   = isBlotter  ? '' : 'none';
    document.getElementById('btnSimple').classList.toggle('active', isSimple);
    document.getElementById('btnAdvanced').classList.toggle('active', isAdvanced);
    document.getElementById('btnBlotter').classList.toggle('active', isBlotter);
    if (isAdvanced && !advancedChartInitialized) {
        setTimeout(initAdvancedChart, 50);
    }
    if (isBlotter && !blotterInitialized) {
        blotterInitialized = true;
        initBlotterView();
    }
}

// ============================================================================
//  SIMPLE VIEW  (original code - unchanged)
// ============================================================================
(function () {
    'use strict';

    var BASE_PRICE   = parseFloat(document.getElementById('livePrice').textContent) || 0.6550;
    var currentPrice = BASE_PRICE;
    var openPrice    = BASE_PRICE;
    var sessionHigh  = BASE_PRICE;
    var sessionLow   = BASE_PRICE;
    var MAX_POINTS   = 120;
    var TICK_MS      = 1000;
    var POLL_MS      = 4000;

    var labels       = [];
    var prices       = [];
    var buyPressure  = 0;
    var knownTradeCount = parseInt(document.getElementById('tradeCount').textContent) || 0;

    function fmt4(n) { return n.toFixed(4); }
    function fmtTime(d) { return d.toTimeString().slice(0, 8); }

    (function seedHistory() {
        var p = BASE_PRICE;
        var now = Date.now();
        for (var i = MAX_POINTS; i >= 0; i--) {
            p += (Math.random() - 0.5) * 0.00025;
            p = parseFloat(p.toFixed(5));
            labels.push(fmtTime(new Date(now - i * TICK_MS)));
            prices.push(p);
        }
        sessionHigh  = Math.max.apply(null, prices);
        sessionLow   = Math.min.apply(null, prices);
        currentPrice = prices[prices.length - 1];
    })();

    var ctx   = document.getElementById('forexChart').getContext('2d');

    function makeGradient(color) {
        var grad = ctx.createLinearGradient(0, 0, 0, 300);
        grad.addColorStop(0, color.replace('1)', '0.25)'));
        grad.addColorStop(1, color.replace('1)', '0.0)'));
        return grad;
    }

    var upColor   = 'rgba(0,200,83,1)';
    var downColor = 'rgba(255,61,87,1)';

    var chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'AUD/USD',
                data: prices,
                borderColor: upColor,
                backgroundColor: makeGradient(upColor),
                borderWidth: 1.5,
                pointRadius: 0,
                fill: true,
                tension: 0.3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 0 },
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1c2230',
                    titleColor: '#8b949e',
                    bodyColor: '#e6edf3',
                    borderColor: '#2d3748',
                    borderWidth: 1,
                    callbacks: {
                        label: function(ctx) { return ' ' + fmt4(ctx.parsed.y); }
                    }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#8b949e', maxTicksLimit: 8, font: { size: 11 } },
                    grid:  { color: 'rgba(45,55,72,0.6)' }
                },
                y: {
                    position: 'right',
                    ticks: {
                        color: '#8b949e',
                        font: { size: 11 },
                        callback: function(v) { return fmt4(v); }
                    },
                    grid: { color: 'rgba(45,55,72,0.6)' }
                }
            }
        }
    });

    function tick() {
        var rand  = (Math.random() + Math.random() + Math.random() - 1.5) / 3;
        var drift = rand * 0.00018;
        drift    += buyPressure * 0.0003;
        buyPressure = buyPressure * 0.7;
        currentPrice = parseFloat((currentPrice + drift).toFixed(5));
        if (currentPrice > openPrice + 0.0200) currentPrice = openPrice + 0.0200;
        if (currentPrice < openPrice - 0.0200) currentPrice = openPrice - 0.0200;
        if (currentPrice > sessionHigh) sessionHigh = currentPrice;
        if (currentPrice < sessionLow)  sessionLow  = currentPrice;
        labels.push(fmtTime(new Date()));
        prices.push(currentPrice);
        if (labels.length > MAX_POINTS) { labels.shift(); prices.shift(); }
        var isUp  = currentPrice >= openPrice;
        var color = isUp ? upColor : downColor;
        chart.data.datasets[0].borderColor     = color;
        chart.data.datasets[0].backgroundColor = makeGradient(color);
        chart.update('none');
        updateTicker();
    }

    function updateTicker() {
        var change    = currentPrice - openPrice;
        var changePct = (change / openPrice) * 100;
        var isUp      = change >= 0;
        document.getElementById('livePrice').textContent   = fmt4(currentPrice);
        document.getElementById('sessionHigh').textContent = fmt4(sessionHigh);
        document.getElementById('sessionLow').textContent  = fmt4(sessionLow);
        var el = document.getElementById('priceChange');
        el.textContent = (isUp ? '\u25b2 +' : '\u25bc ') + fmt4(change) +
                         ' (' + (isUp ? '+' : '') + changePct.toFixed(2) + '%)';
        el.className = 'ticker-change ' + (isUp ? 'up' : 'down');
    }

    function pollTrades() {
        fetch('/api/trades')
            .then(function(r) { return r.json(); })
            .then(function(trades) {
                if (!Array.isArray(trades)) return;
                var newCount = trades.length;
                if (newCount > knownTradeCount) {
                    var added = trades.slice(0, newCount - knownTradeCount);
                    added.forEach(function(t) {
                        if (t.type === 'Buy'  || t.Type === 'Buy')  buyPressure += 1;
                        if (t.type === 'Sell' || t.Type === 'Sell') buyPressure -= 1;
                    });
                    knownTradeCount = newCount;
                    document.getElementById('tradeCount').textContent = newCount;
                    refreshTradeTable(trades);
                }
            })
            .catch(function(err) { console.error('[Trading Platform] trade poll error:', err); });
    }

    function refreshTradeTable(trades) {
        var tbody = document.getElementById('tradeTableBody');
        var html  = '';
        trades.forEach(function(t) {
            var type    = t.type || t.Type || '';
            var isGreen = type === 'Buy';
            html += '<tr>' +
                '<td>' + (t.id || t.Id || '') + '</td>' +
                '<td><span class="badge ' + (isGreen ? 'badge-buy' : 'badge-sell') + '">' + type + '</span></td>' +
                '<td>' + (t.currencyPair || t.CurrencyPair || '') + '</td>' +
                '<td>$' + parseFloat(t.amount || t.Amount || 0).toFixed(2) + '</td>' +
                '<td>' + parseFloat(t.rate || t.Rate || 0).toFixed(4) + '</td>' +
                '<td>$' + parseFloat(t.total || t.Total || 0).toFixed(2) + '</td>' +
                '<td>' + formatDateTime(t.dateTime || t.DateTime || '') + '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    function formatDateTime(dt) {
        if (!dt) return '';
        var d = new Date(dt);
        if (isNaN(d)) return dt;
        return d.getFullYear() + '-' +
               String(d.getMonth() + 1).padStart(2, '0') + '-' +
               String(d.getDate()).padStart(2, '0') + ' ' +
               String(d.getHours()).padStart(2, '0') + ':' +
               String(d.getMinutes()).padStart(2, '0');
    }

    setInterval(tick,       TICK_MS);
    setInterval(pollTrades, POLL_MS);
    pollTrades();
})();

// ============================================================================
//  ADVANCED VIEW  –  Custom Canvas candlestick chart
// ============================================================================
(function () {
    'use strict';

    var CANDLE_COUNT = 100;
    var tfMinutes    = 1;
    var tfSeconds    = 60;

    var PAD_LEFT   = 8;
    var PAD_RIGHT  = 68;
    var PAD_TOP    = 12;
    var PAD_BOTTOM = 34;

    var COLOR_UP           = '#26a69a';
    var COLOR_DOWN         = '#ef5350';
    var COLOR_GRID         = '#f0f3fb';
    var COLOR_AXIS         = '#9aa0ac';
    var COLOR_PRICE_LINE   = '#4595e6';
    var COLOR_MARKER_FILL  = '#F6BE00';
    var COLOR_MARKER_STROKE = '#c9930a';
    var MARKER_RADIUS = 11;
    // Extra candles kept in memory beyond CANDLE_COUNT to absorb new-candle
    // additions without triggering a shift on every tick.
    var CANDLE_BUFFER = 30;

    var candles = [];
    var markers = [];
    var canvas, ctx2d;
    var tickTimer, pollTimer, candleTimer;

    window.initAdvancedChart = function () {
        advancedChartInitialized = true;

        canvas = document.getElementById('advCanvas');
        ctx2d  = canvas.getContext('2d');

        generateCandles();
        resizeCanvas();

        if (window.ResizeObserver) {
            var ro = new ResizeObserver(resizeCanvas);
            ro.observe(document.getElementById('advChartContainer'));
        } else {
            window.addEventListener('resize', resizeCanvas);
        }

        tickTimer   = setInterval(advTick,      1000);
        candleTimer = setInterval(advNewCandle, tfSeconds * 1000);
        pollTimer   = setInterval(loadMarkers,  4000);
        loadMarkers();

        document.querySelectorAll('.tf-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.tf-btn').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                tfMinutes = parseInt(btn.getAttribute('data-tf'), 10);
                tfSeconds = tfMinutes * 60;
                document.getElementById('advTfLabel').textContent =
                    btn.getAttribute('data-label') + ' \u00b7 Real-time Currencies';
                clearInterval(candleTimer);
                candleTimer = setInterval(advNewCandle, tfSeconds * 1000);
                generateCandles();
                loadMarkers();
            });
        });
    };

    function generateCandles() {
        candles = [];
        var basePrice = parseFloat(document.getElementById('livePrice').textContent) || 0.6550;
        var price = basePrice;
        var nowS  = Math.floor(Date.now() / 1000);
        var startS = Math.floor(nowS / tfSeconds) * tfSeconds - (CANDLE_COUNT - 1) * tfSeconds;

        for (var i = 0; i < CANDLE_COUNT; i++) {
            var t     = startS + i * tfSeconds;
            var open  = price;
            var sigma = 0.00012 * Math.sqrt(tfMinutes);
            var chg   = (Math.random() + Math.random() - 1) * sigma;
            var close = parseFloat((open + chg).toFixed(5));
            var hi    = parseFloat((Math.max(open, close) + Math.random() * sigma * 0.6).toFixed(5));
            var lo    = parseFloat((Math.min(open, close) - Math.random() * sigma * 0.6).toFixed(5));
            candles.push({ time: t, open: open, high: hi, low: lo, close: close });
            price = close;
        }
        drawChart();
        updateOHLC(candles[candles.length - 1]);
    }

    function resizeCanvas() {
        var container = document.getElementById('advChartContainer');
        if (!container || !canvas) return;
        canvas.width  = container.clientWidth  || container.offsetWidth  || 800;
        canvas.height = container.clientHeight || container.offsetHeight || 420;
        drawChart();
    }

    function loadMarkers() {
        fetch('/api/trades')
            .then(function (r) { return r.json(); })
            .then(function (trades) {
                if (!Array.isArray(trades)) return;
                markers = trades.map(function (t) {
                    var type = t.type || t.Type || '';
                    var dt   = new Date(t.dateTime || t.DateTime || '');
                    return { time: Math.floor(dt.getTime() / 1000), type: type, label: type === 'Buy' ? 'B' : 'S' };
                }).filter(function (m) { return !isNaN(m.time) && m.time > 0; });
                drawChart();
            })
            .catch(function () {});
    }

    function advTick() {
        if (candles.length === 0) return;
        var last = candles[candles.length - 1];
        // Sync close price with the simple-view tick (which already applies buy/sell
        // pressure) so both tabs always show the same live price.
        var livePriceEl = document.getElementById('livePrice');
        var syncedPrice = livePriceEl ? parseFloat(livePriceEl.textContent) : NaN;
        if (isNaN(syncedPrice) || syncedPrice <= 0) {
            // Fallback: apply independent drift when livePrice is unavailable
            var sigma = 0.00010 * Math.sqrt(tfMinutes);
            syncedPrice = parseFloat((last.close + (Math.random() + Math.random() - 1) * sigma * 0.5).toFixed(5));
        }
        last.close = syncedPrice;
        if (last.close > last.high) last.high = last.close;
        if (last.close < last.low)  last.low  = last.close;
        drawChart();
        updateOHLC(last);
    }

    function advNewCandle() {
        if (candles.length === 0) return;
        var prev = candles[candles.length - 1];
        candles.push({ time: prev.time + tfSeconds, open: prev.close, high: prev.close, low: prev.close, close: prev.close });
        if (candles.length > CANDLE_COUNT + CANDLE_BUFFER) candles.shift();
    }

    function updateOHLC(c) {
        if (!c) return;
        document.getElementById('advO').textContent = c.open.toFixed(4);
        document.getElementById('advH').textContent = c.high.toFixed(4);
        document.getElementById('advL').textContent = c.low.toFixed(4);
        document.getElementById('advC').textContent = c.close.toFixed(4);
    }

    function drawChart() {
        if (!ctx2d || !canvas || canvas.width === 0) return;

        var W  = canvas.width;
        var H  = canvas.height;
        var cx = ctx2d;

        cx.fillStyle = '#ffffff';
        cx.fillRect(0, 0, W, H);

        var x0 = PAD_LEFT;
        var x1 = W - PAD_RIGHT;
        var y0 = PAD_TOP;
        var y1 = H - PAD_BOTTOM;
        var cW = x1 - x0;
        var cH = y1 - y0;
        if (cW <= 0 || cH <= 0) return;

        var vis = candles.slice(-CANDLE_COUNT);
        if (vis.length === 0) return;

        var minP = Infinity, maxP = -Infinity;
        vis.forEach(function (c) {
            if (c.low  < minP) minP = c.low;
            if (c.high > maxP) maxP = c.high;
        });
        var range  = maxP - minP || 0.001;
        var margin = range * 0.12;
        minP -= margin;
        maxP += margin;

        var n = vis.length;
        function toX(i) { return x0 + (i + 0.5) * (cW / n); }
        function toY(p)  { return y1 - ((p - minP) / (maxP - minP)) * cH; }

        var candleW = Math.max(1, Math.floor(cW / n * 0.65));

        // Grid
        cx.strokeStyle = COLOR_GRID;
        cx.lineWidth   = 1;
        var gridRows = 6;
        for (var g = 0; g <= gridRows; g++) {
            var gy = y0 + (cH / gridRows) * g;
            cx.beginPath(); cx.moveTo(x0, gy); cx.lineTo(x1, gy); cx.stroke();
        }

        // Candles
        vis.forEach(function (c, i) {
            var isUp = c.close >= c.open;
            var col  = isUp ? COLOR_UP : COLOR_DOWN;
            var xc   = toX(i);
            cx.strokeStyle = col;
            cx.lineWidth   = 1;
            cx.beginPath(); cx.moveTo(xc, toY(c.high)); cx.lineTo(xc, toY(c.low)); cx.stroke();
            var bodyY = toY(Math.max(c.open, c.close));
            var bodyH = Math.max(1, Math.abs(toY(c.open) - toY(c.close)));
            cx.fillStyle = col;
            cx.fillRect(xc - candleW / 2, bodyY, candleW, bodyH);
        });

        // Trade markers – build time-boundary map for O(n + m) lookup
        var candleMap = {};
        vis.forEach(function (c, i) { candleMap[c.time] = i; });

        markers.forEach(function (m) {
            // Align marker timestamp to the enclosing candle boundary
            var candleTime = Math.floor(m.time / tfSeconds) * tfSeconds;
            var mIdx = (candleTime in candleMap) ? candleMap[candleTime] : -1;
            if (mIdx < 0) return;
            var xm = toX(mIdx);
            var c  = vis[mIdx];
            var ym = (m.type === 'Buy')
                ? toY(c.low)  + MARKER_RADIUS + 4
                : toY(c.high) - MARKER_RADIUS - 4;
            cx.beginPath();
            cx.arc(xm, ym, MARKER_RADIUS, 0, Math.PI * 2);
            cx.fillStyle   = COLOR_MARKER_FILL;
            cx.fill();
            cx.strokeStyle = COLOR_MARKER_STROKE;
            cx.lineWidth   = 1.5;
            cx.stroke();
            cx.fillStyle    = '#222';
            cx.font         = 'bold 10px Arial, sans-serif';
            cx.textAlign    = 'center';
            cx.textBaseline = 'middle';
            cx.fillText(m.label, xm, ym);
        });

        // Current price line
        var lastClose = vis[vis.length - 1].close;
        var priceY    = toY(lastClose);
        cx.strokeStyle = COLOR_PRICE_LINE;
        cx.lineWidth   = 1;
        cx.setLineDash([4, 4]);
        cx.beginPath(); cx.moveTo(x0, priceY); cx.lineTo(x1, priceY); cx.stroke();
        cx.setLineDash([]);

        // Price badge
        var badgeW = PAD_RIGHT - 4;
        cx.fillStyle = COLOR_PRICE_LINE;
        cx.fillRect(x1 + 1, priceY - 10, badgeW, 20);
        cx.fillStyle    = '#fff';
        cx.font         = 'bold 11px Arial, sans-serif';
        cx.textAlign    = 'center';
        cx.textBaseline = 'middle';
        cx.fillText(lastClose.toFixed(4), x1 + 1 + badgeW / 2, priceY);

        // Price axis labels
        cx.fillStyle    = COLOR_AXIS;
        cx.font         = '10px Arial, sans-serif';
        cx.textAlign    = 'left';
        cx.textBaseline = 'middle';
        for (var p = 0; p <= gridRows; p++) {
            var pr  = minP + (maxP - minP) * (1 - p / gridRows);
            var pry = y0 + (cH / gridRows) * p;
            if (Math.abs(pry - priceY) < 12) continue;
            cx.fillText(pr.toFixed(4), x1 + 4, pry);
        }

        // Time axis labels
        cx.fillStyle    = COLOR_AXIS;
        cx.font         = '10px Arial, sans-serif';
        cx.textAlign    = 'center';
        cx.textBaseline = 'top';
        var step = Math.max(1, Math.floor(n / 8));
        for (var ti = 0; ti < n; ti += step) {
            var td  = new Date(vis[ti].time * 1000);
            var lbl = String(td.getHours()).padStart(2, '0') + ':' +
                      String(td.getMinutes()).padStart(2, '0');
            cx.fillText(lbl, toX(ti), y1 + 4);
        }

        // Border
        cx.strokeStyle = '#d8dce8';
        cx.lineWidth   = 1;
        cx.strokeRect(x0, y0, cW, cH);
    }

})();

// ============================================================================
//  BLOTTER / AURORA VIEW
// ============================================================================
(function () {
    'use strict';

    // ── Static pair definitions ──────────────────────────────────────────────
    var PAIRS = [
        { pair: 'EUR/USD', base: 1.1715, flag: '🇪🇺🇺🇸' },
        { pair: 'AUD/USD', base: 0.6528, flag: '🇦🇺🇺🇸' },
        { pair: 'USD/JPY', base: 144.37, flag: '🇺🇸🇯🇵' },
        { pair: 'GBP/USD', base: 1.3699, flag: '🇬🇧🇺🇸' },
        { pair: 'USD/CHF', base: 0.9025, flag: '🇺🇸🇨🇭' },
        { pair: 'USD/CNH', base: 7.1623, flag: '🇺🇸🇨🇳' },
        { pair: 'USD/HKD', base: 7.8498, flag: '🇺🇸🇭🇰' },
        { pair: 'EUR/GBP', base: 0.8550, flag: '🇪🇺🇬🇧' },
        { pair: 'AUD/NZD', base: 1.0812, flag: '🇦🇺🇳🇿' },
        { pair: 'USD/SGD', base: 1.3540, flag: '🇺🇸🇸🇬' },
        { pair: 'USD/ZAR', base: 17.790, flag: '🇺🇸🇿🇦' },
        { pair: 'XAU/USD', base: 3282.5, flag: '🥇🇺🇸' }
    ];

    var pairState = {};   // { pair: { mid, spread, activeTenor } }

    // ── Helpers ──────────────────────────────────────────────────────────────
    function rand(min, max) { return min + Math.random() * (max - min); }

    function formatRate(val, base) {
        if (base >= 100) return val.toFixed(2);
        if (base >= 10)  return val.toFixed(3);
        return val.toFixed(4);
    }

    function splitRate(val, base) {
        var s     = formatRate(val, base);
        var parts = s.split('.');
        var whole = parts[0];
        var dec   = parts[1] || '';
        // prefix = whole + first 2 decimals, pips = next 2, suffix = last 1 (if any)
        if (base >= 100) {
            // e.g. 144.37 → prefix "144.", pips "37", suffix ""
            return { prefix: whole + '.', pips: dec.slice(0, 2), suffix: dec.slice(2) };
        }
        // e.g. 1.17149 → prefix "1.", pips "17", suffix "149"→show "14" + "9" hint
        return { prefix: whole + '.', pips: dec.slice(0, 2), suffix: dec.slice(2) };
    }

    function settleDate() {
        var d = new Date();
        d.setDate(d.getDate() + 2);
        return d.toISOString().slice(0, 10);
    }

    function nowStr() {
        var n = new Date();
        return n.toISOString().slice(0, 10) + ' ' + n.toTimeString().slice(0, 8);
    }

    // ── Init pair state ───────────────────────────────────────────────────────
    function initPairState() {
        PAIRS.forEach(function (p) {
            var sp = p.base >= 100 ? rand(0.008, 0.02) : rand(0.00015, 0.0004);
            pairState[p.pair] = {
                mid: p.base,
                spread: sp,
                activeTenor: '1M'
            };
        });
    }

    // ── Render tiles ─────────────────────────────────────────────────────────
    function renderTiles() {
        var grid = document.getElementById('fxTilesGrid');
        if (!grid) return;
        grid.innerHTML = '';
        PAIRS.forEach(function (p) {
            var tile = buildTile(p);
            grid.appendChild(tile);
        });
    }

    function buildTile(p) {
        var st      = pairState[p.pair];
        var sell    = st.mid - st.spread / 2;
        var buy     = st.mid + st.spread / 2;
        var sellSp  = splitRate(sell, p.base);
        var buySp   = splitRate(buy,  p.base);
        var pipDiff = Math.round(st.spread / (p.base >= 100 ? 0.005 : 0.00005));
        var settle  = settleDate();
        var tenors  = ['1M', '2M', '5M', '10M'];

        var div = document.createElement('div');
        div.className = 'fx-tile';
        div.id = 'tile-' + p.pair.replace('/', '');

        div.innerHTML =
            '<div class="fx-tile-header">' +
                '<span style="margin-right:3px;font-size:0.75rem">' + p.flag + '</span>' +
                '<span class="fx-tile-pair">' + p.pair + '</span>' +
                '<span class="fx-tile-badge">SPOT</span>' +
                '<span class="fx-tile-rfq">RFQ</span>' +
                '<button class="fx-tile-close" onclick="removeTile(\'' + p.pair + '\')">&#x2715;</button>' +
            '</div>' +
            '<div class="fx-tile-rates">' +
                '<div class="fx-rate-side fx-rate-sell" onclick="openOrder(\'' + p.pair + '\',\'SELL\')">' +
                    '<div class="fx-rate-label">SELL ' + p.pair.split('/')[0] + '</div>' +
                    '<div class="fx-rate-num-row">' +
                        '<span class="fx-rate-prefix">' + sellSp.prefix + '</span>' +
                        '<span class="fx-rate-pips" id="sell-pips-' + p.pair.replace('/', '') + '">' + sellSp.pips + '</span>' +
                        '<span class="fx-rate-suffix">' + sellSp.suffix + '</span>' +
                    '</div>' +
                '</div>' +
                '<div class="fx-rate-spread">' +
                    '<span>' + pipDiff + '</span>' +
                    '<span style="font-size:0.5rem;color:#4a5568">pip</span>' +
                '</div>' +
                '<div class="fx-rate-side fx-rate-buy" onclick="openOrder(\'' + p.pair + '\',\'BUY\')">' +
                    '<div class="fx-rate-label">BUY ' + p.pair.split('/')[0] + '</div>' +
                    '<div class="fx-rate-num-row">' +
                        '<span class="fx-rate-prefix">' + buySp.prefix + '</span>' +
                        '<span class="fx-rate-pips" id="buy-pips-' + p.pair.replace('/', '') + '">' + buySp.pips + '</span>' +
                        '<span class="fx-rate-suffix">' + buySp.suffix + '</span>' +
                    '</div>' +
                '</div>' +
            '</div>' +
            '<div class="fx-tile-tenors">' +
                tenors.map(function (t) {
                    return '<button class="fx-tenor-btn' + (t === st.activeTenor ? ' active' : '') +
                           '" onclick="setTenor(\'' + p.pair + '\',\'' + t + '\',this)">' + t + '</button>';
                }).join('') +
            '</div>' +
            '<div class="fx-tile-footer">' +
                '<span class="fx-notional-val">1,000,000.00</span>' +
                '<span class="fx-settle">' + p.pair.split('/')[0] + ' SP ' + settle + '</span>' +
                '<button class="fx-order-btn" onclick="openOrder(\'' + p.pair + '\',\'BUY\')">ORDER</button>' +
            '</div>';

        return div;
    }

    // ── Tick: update pip cells only ───────────────────────────────────────────
    function tickBlotter() {
        PAIRS.forEach(function (p) {
            var st = pairState[p.pair];
            var drift = (Math.random() + Math.random() - 1) * (p.base >= 100 ? 0.008 : 0.00006);
            st.mid = parseFloat((st.mid + drift).toFixed(p.base >= 100 ? 3 : 5));

            var sell = st.mid - st.spread / 2;
            var buy  = st.mid + st.spread / 2;
            var key  = p.pair.replace('/', '');
            var sellEl = document.getElementById('sell-pips-' + key);
            var buyEl  = document.getElementById('buy-pips-'  + key);
            if (sellEl) sellEl.textContent = splitRate(sell, p.base).pips;
            if (buyEl)  buyEl.textContent  = splitRate(buy,  p.base).pips;
        });
    }

    // ── Tenor selection ───────────────────────────────────────────────────────
    window.setTenor = function (pair, tenor, btn) {
        pairState[pair].activeTenor = tenor;
        var tile = document.getElementById('tile-' + pair.replace('/', ''));
        if (!tile) return;
        tile.querySelectorAll('.fx-tenor-btn').forEach(function (b) {
            b.classList.toggle('active', b.textContent === tenor);
        });
    };

    // ── Remove tile ───────────────────────────────────────────────────────────
    window.removeTile = function (pair) {
        var key = 'tile-' + pair.replace('/', '');
        var el  = document.getElementById(key);
        if (el) el.remove();
        PAIRS = PAIRS.filter(function (p) { return p.pair !== pair; });
    };

    window.addCcyPrompt = function () {
        var pair = prompt('Enter currency pair (e.g. USD/MXN):');
        if (!pair) return;
        pair = pair.toUpperCase().trim();
        if (PAIRS.some(function (p) { return p.pair === pair; })) return;
        var base = parseFloat(prompt('Enter mid rate for ' + pair + ':') || '1');
        if (isNaN(base) || base <= 0) return;
        PAIRS.push({ pair: pair, base: base, flag: '🌐' });
        var sp = base >= 100 ? rand(0.008, 0.02) : rand(0.00015, 0.0004);
        pairState[pair] = { mid: base, spread: sp, activeTenor: '1M' };
        var grid = document.getElementById('fxTilesGrid');
        if (grid) grid.appendChild(buildTile(PAIRS[PAIRS.length - 1]));
    };

    // ── Order ticket ──────────────────────────────────────────────────────────
    var activePair = '';

    window.openOrder = function (pair, direction) {
        activePair = pair;
        var st  = pairState[pair];
        var mid = st ? st.mid : 0;
        var base = (PAIRS.find(function (p) { return p.pair === pair; }) || {}).base || 1;

        document.getElementById('otPairLabel').textContent = pair;
        document.getElementById('otMktPrice').textContent  = formatRate(mid, base);
        document.getElementById('otLimitPrice').value      = formatRate(mid, base);
        document.getElementById('otMktPips').textContent   = '';

        var parts = pair.split('/');
        document.getElementById('otCcyToggle').innerHTML =
            '<button class="ot-tog active-ccy" id="otCcy0" onclick="setCcy(0)">' + parts[0] + '</button>' +
            '<button class="ot-tog"            id="otCcy1" onclick="setCcy(1)">' + parts[1] + '</button>';

        setDirection(direction);
        document.getElementById('orderOverlay').style.display = 'flex';
    };

    window.closeOrderTicket = function () {
        document.getElementById('orderOverlay').style.display = 'none';
    };

    window.setDirection = function (dir) {
        document.getElementById('otBuyBtn').className  = 'ot-tog' + (dir === 'BUY'  ? ' active-buy'  : '');
        document.getElementById('otSellBtn').className = 'ot-tog' + (dir === 'SELL' ? ' active-sell' : '');
    };

    window.setCcy = function (idx) {
        document.getElementById('otCcy0').className = 'ot-tog' + (idx === 0 ? ' active-ccy' : '');
        document.getElementById('otCcy1').className = 'ot-tog' + (idx === 1 ? ' active-ccy' : '');
    };

    window.stepQty = function (delta) {
        var el  = document.getElementById('otQty');
        var val = parseFloat((el.value || '0').replace(/,/g, '')) + delta;
        if (val < 0) val = 0;
        el.value = val.toLocaleString('en-US', { minimumFractionDigits: 2 });
    };

    window.stepPrice = function (delta) {
        var el  = document.getElementById('otLimitPrice');
        var val = parseFloat(el.value || '0') + delta;
        if (val < 0) val = 0;
        el.value = val.toFixed(4);
    };

    window.resetOrderTicket = function () {
        document.getElementById('otQty').value        = '1,000,000.00';
        document.getElementById('otLimitPrice').value = document.getElementById('otMktPrice').textContent;
        document.getElementById('otMktPips').textContent = '';
        setDirection('BUY');
    };

    window.cloneOrder = function () {
        closeOrderTicket();
        setTimeout(function () {
            openOrder(activePair, document.getElementById('otBuyBtn').classList.contains('active-buy') ? 'BUY' : 'SELL');
        }, 150);
    };

    window.submitOrder = function () {
        var dir  = document.getElementById('otBuyBtn').classList.contains('active-buy') ? 'BUY' : 'SELL';
        var qty  = document.getElementById('otQty').value;
        var px   = document.getElementById('otLimitPrice').value;
        var type = document.getElementById('otOrderType').value;
        addBlotterRow(dir, activePair, qty, px, type, 'WORKING');
        closeOrderTicket();
    };

    // ── Blotter rows ──────────────────────────────────────────────────────────
    var blotterRows = [];

    function loadBlotterFromTransactions() {
        fetch('/api/trades')
            .then(function (r) { return r.json(); })
            .then(function (trades) {
                if (!Array.isArray(trades)) return;
                trades.slice(0, 10).forEach(function (t) {
                    var side  = (t.type || t.Type || 'BUY').toUpperCase();
                    var pair  = t.currencyPair || t.CurrencyPair || 'EUR/USD';
                    var qty   = parseFloat(t.amount || t.Amount || 1000000).toLocaleString();
                    var px    = parseFloat(t.rate   || t.Rate   || 0).toFixed(4);
                    var parts = pair.split('/');
                    blotterRows.unshift({ side: side, pair: pair, qty: qty, px: px, orderType: 'RFQ',
                        status: 'FILLED', ccy: parts[0], cumQty: qty, avgPx: px,
                        created: (t.dateTime || t.DateTime || ''), tif: 'GTC', contra: parts[1] + ':MKT' });
                });
                renderBlotter();
            })
            .catch(function () {});
    }

    window.addBlotterRow = function (side, pair, qty, px, orderType, status) {
        var parts = pair.split('/');
        var now   = nowStr();
        blotterRows.unshift({ side: side, pair: pair, qty: qty, px: px, orderType: orderType,
            status: status, ccy: parts[0], cumQty: '0', avgPx: '—',
            created: now, tif: 'GTC', contra: parts[1] + ':LMT' });
        renderBlotter();
        // Simulate fill after 2 seconds
        setTimeout(function () {
            if (blotterRows[0]) {
                blotterRows[0].status = 'FILLED';
                blotterRows[0].cumQty = blotterRows[0].qty;
                blotterRows[0].avgPx  = blotterRows[0].px;
                renderBlotter();
            }
        }, 2000);
    };

    function renderBlotter() {
        var tbody = document.getElementById('blotterTbody');
        if (!tbody) return;
        var html = '';
        blotterRows.forEach(function (r) {
            var stCls   = r.status === 'FILLED' ? 'st-filled' : 'st-working';
            var sideCls = r.side   === 'BUY'    ? 'side-buy'  : 'side-sell';
            var dt = r.created ? new Date(r.created) : null;
            var dtStr = dt && !isNaN(dt) ? dt.toISOString().slice(0, 10) + ' ' + dt.toTimeString().slice(0, 8) : r.created;
            html +=
                '<tr>' +
                '<td>' + dtStr + '</td>' +
                '<td>' + dtStr + '</td>' +
                '<td><span class="' + stCls + '">' + r.status + '</span></td>' +
                '<td>' + r.orderType + '</td>' +
                '<td>PROP-01</td>' +
                '<td>SPOT</td>' +
                '<td>' + r.pair + '</td>' +
                '<td class="' + sideCls + '">' + r.side + '</td>' +
                '<td>' + r.ccy + '</td>' +
                '<td>' + r.qty + '</td>' +
                '<td>' + r.cumQty + '</td>' +
                '<td>' + r.avgPx + '</td>' +
                '<td>GTC</td>' +
                '<td>' + r.contra + '</td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    // ── Initialise ────────────────────────────────────────────────────────────
    window.initBlotterView = function () {
        initPairState();
        renderTiles();
        loadBlotterFromTransactions();
        setInterval(tickBlotter, 1200);
    };

    // Close overlay on background click
    document.addEventListener('click', function (e) {
        var overlay = document.getElementById('orderOverlay');
        if (overlay && e.target === overlay) { closeOrderTicket(); }
    });

})();
</script>
