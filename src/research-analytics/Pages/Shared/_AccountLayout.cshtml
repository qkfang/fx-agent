@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Account</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="account-body">
    <nav class="navbar navbar-expand-lg account-navbar">
        <div class="container-xl">
            <a class="navbar-brand account-brand" href="/Account">
                <span class="logo-fx">FX</span><span class="logo-research">Research</span>
                <span class="account-badge ms-2">My Account</span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="text-white-50 small d-none d-md-block">
                    <i class="fa-regular fa-circle-user me-1"></i>@ViewData["DisplayName"]
                </span>
                <a href="/" class="btn btn-sm btn-outline-light">View Portal</a>
                <a href="/Account/Logout" class="btn btn-sm btn-outline-danger">Sign Out</a>
            </div>
        </div>
    </nav>
    <div class="container-xl mt-4 pb-5">
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
