@page
@model FxWebPortal.Pages.Account.IndexModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "My Account";
    ViewData["DisplayName"] = Model.DisplayName;
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Profile header -->
<div class="account-profile-header mb-4">
    <div class="d-flex align-items-center gap-3">
        <div class="account-avatar">
            <i class="fa-solid fa-circle-user"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold">@Model.DisplayName</h4>
            <div class="text-muted small mt-1">
                Interests:
                @foreach (var interest in Model.Interests)
                {
                    <span class="cat-badge cat-@(interest.Replace("/","-").Replace(" ","-").ToLower()) me-1">@interest</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs account-tabs mb-4" id="accountTabs">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-insights">
            <i class="fa-solid fa-chart-line me-1"></i> Market Insights
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-suggestions">
            <i class="fa-solid fa-robot me-1"></i> Recommendations
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-customer-suggestions">
            <i class="fa-solid fa-lightbulb me-1"></i> Customer Suggestions
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="tab-chat-btn" data-bs-toggle="tab" data-bs-target="#tab-chat">
            <i class="fa-solid fa-comments me-1"></i> Ask AI
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- ── Tab 1: Market Insights ── -->
    <div class="tab-pane fade show active" id="tab-insights">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">Market Insights</h5>
                <p class="text-muted small mb-0 mt-1">Research filtered to your interests: <strong>@string.Join(", ", Model.Interests)</strong></p>
            </div>
            <span class="badge bg-danger fs-6">@Model.MarketInsights.Count articles</span>
        </div>

        @if (Model.MarketInsights.Any())
        {
            <div class="row g-4">
                @foreach (var article in Model.MarketInsights)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="article-card h-100">
                            <div class="article-card-header">
                                <span class="cat-badge cat-@(article.Category.Replace("/","-").Replace(" ","-").ToLower())">@article.Category</span>
                                <span class="sentiment-badge sentiment-@article.Sentiment.ToLower()">@article.Sentiment</span>
                            </div>
                            <div class="article-card-body">
                                <h2 class="article-title">
                                    <a href="/Article?id=@article.Id" target="_blank">@article.Title</a>
                                </h2>
                                <p class="article-summary">@article.Summary</p>
                            </div>
                            <div class="article-card-footer">
                                <span class="article-author">@article.Author</span>
                                <span class="article-date">@article.PublishedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fa-solid fa-newspaper fa-2x mb-3 d-block"></i>
                No published articles match your interests yet. Check back soon.
            </div>
        }
    </div>

    <!-- ── Tab 2: Recommendations ── -->
    <div class="tab-pane fade" id="tab-suggestions">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">Recommendations</h5>
                <p class="text-muted small mb-0 mt-1">Trading recommendations for your account</p>
            </div>
            <span class="badge bg-danger fs-6">@Model.Recommendations.Count</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>Pair</th>
                        <th>Direction</th>
                        <th>Target Rate</th>
                        <th>Stop Loss</th>
                        <th>Confidence</th>
                        <th>Rationale</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Expires</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Recommendations)
                    {
                        <tr>
                            <td><span class="cat-badge cat-@(r.CurrencyPair.Replace("/","-").Replace(" ","-").ToLower())">@r.CurrencyPair</span></td>
                            <td>
                                @if (r.Direction == "Buy")
                                {
                                    <span class="sentiment-badge sentiment-bullish">▲ Buy</span>
                                }
                                else
                                {
                                    <span class="sentiment-badge sentiment-bearish">▼ Sell</span>
                                }
                            </td>
                            <td>@r.TargetRate</td>
                            <td>@r.StopLoss</td>
                            <td>
                                @if (r.Confidence == "High")
                                {
                                    <span class="badge bg-success">High</span>
                                }
                                else if (r.Confidence == "Medium")
                                {
                                    <span class="badge bg-warning text-dark">Medium</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Low</span>
                                }
                            </td>
                            <td class="suggestion-analysis" title="@r.Rationale">
                                @TextHelper.Truncate(r.Rationale, 90)
                            </td>
                            <td><span class="badge bg-info text-dark">@r.Status</span></td>
                            <td class="text-muted small">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-muted small">@(r.ExpiresAt?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <a href="/Account/AuroraWorkflow?customer=Trader&customerId=ACC001&pair=@Uri.EscapeDataString(r.CurrencyPair)&signal=@Uri.EscapeDataString(r.Direction)"
                                   class="btn btn-xs btn-aurora"
                                   title="Open Action workflow for @r.CurrencyPair — @r.Direction">
                                    ✦ Action
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Recommendations.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">No recommendations yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Tab 3: Customer Suggestions ── -->
    <div class="tab-pane fade" id="tab-customer-suggestions">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">Customer Suggestions</h5>
                <p class="text-muted small mb-0 mt-1">AI-generated suggestions linking customers to research articles</p>
            </div>
            <span class="badge bg-danger fs-6">@Model.TraderSuggestions.Count</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Company</th>
                        <th>Article</th>
                        <th>Reasoning</th>
                        <th>Relevance</th>
                        <th>Status</th>
                        <th>Trader</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.TraderSuggestions)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@(s.Customer?.Name ?? "-")</div>
                                <div class="text-muted small">@(s.Customer?.Email ?? "")</div>
                            </td>
                            <td>@(s.Customer?.Company ?? "-")</td>
                            <td class="suggestion-analysis" title="@(s.ResearchArticle?.Title ?? "")">
                                <a href="/Article?id=@(s.ResearchArticleId)" target="_blank">@TextHelper.Truncate(s.ResearchArticle?.Title ?? "-", 60)</a>
                            </td>
                            <td class="suggestion-analysis" title="@s.Reasoning">
                                @TextHelper.Truncate(s.Reasoning, 80)
                            </td>
                            <td>
                                @if (s.RelevanceScore == "High")
                                {
                                    <span class="badge bg-success">High</span>
                                }
                                else if (s.RelevanceScore == "Medium")
                                {
                                    <span class="badge bg-warning text-dark">Medium</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@s.RelevanceScore</span>
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@s.Status</span></td>
                            <td class="text-muted small">@(s.Trader?.Name ?? "-")</td>
                            <td class="text-muted small">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="d-flex gap-1 flex-wrap">
                                @{
                                    var articleTags = s.ResearchArticle?.Tags ?? string.Empty;
                                    var pair = articleTags.Split(',').FirstOrDefault(t => t.Contains('/')) ?? "AUD/USD";
                                    var signal = (s.ResearchArticle?.Sentiment ?? "") == "Bearish" ? "Sell" : "Buy";
                                    var customerName = s.Customer?.Name ?? "Customer";
                                }
                                <a href="tel:@(s.Customer?.Phone ?? "")" class="btn btn-xs btn-outline-success" title="Call @customerName at @(s.Customer?.Phone ?? "")">
                                    📞 Call
                                </a>
                                <a href="/Account/AuroraWorkflow?customer=@Uri.EscapeDataString(customerName)&customerId=@s.CustomerId&pair=@Uri.EscapeDataString(pair)&signal=@Uri.EscapeDataString(signal)"
                                   class="btn btn-xs btn-aurora"
                                   title="Open Action workflow for @customerName — @signal @pair">
                                    ✦ Action
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.TraderSuggestions.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No customer suggestions available yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Tab 4: Ask AI ── -->
    <div class="tab-pane fade" id="tab-chat">
        <!-- Settings bar -->
        <div class="d-flex align-items-center gap-3 mb-3 p-3 aichat-settings">
            <i class="fa-solid fa-sliders text-muted"></i>
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0 small fw-semibold">Temperature</label>
                <input type="range" class="form-range aichat-temp-slider" id="aichat-temp"
                       min="0" max="1" step="0.05" value="0.7" style="width:120px;">
                <span class="badge bg-secondary" id="aichat-temp-label">0.7</span>
            </div>
            <div class="d-flex align-items-center gap-2 ms-3">
                <label class="form-label mb-0 small fw-semibold">Model</label>
                <select class="form-select form-select-sm aichat-select" id="aichat-model" style="width:auto;">
                    <option value="fxag-insight">fxag-insight</option>
                    <option value="fxag-research">fxag-research</option>
                </select>
            </div>
            <button class="btn btn-xs btn-outline-secondary ms-auto" id="aichat-clear" title="Clear conversation">
                <i class="fa-solid fa-trash-can me-1"></i>Clear
            </button>
        </div>

        <!-- Two-column layout: chat | references -->
        <div class="d-flex gap-3" style="height:600px;">

            <!-- Chat panel -->
            <div class="d-flex flex-column flex-fill aichat-panel" style="min-width:0;">
                <div class="aichat-messages flex-fill overflow-auto p-3" id="aichat-messages">
                    <div class="aichat-welcome">
                        <i class="fa-solid fa-brain fa-2x mb-2"></i>
                        <p class="mb-1 fw-semibold">Research AI Assistant</p>
                        <p class="small text-muted">Ask about market conditions, currency pairs, or trading strategy. Relevant articles will appear on the right.</p>
                    </div>
                </div>
                <div class="aichat-composer p-2">
                    <div class="input-group">
                        <textarea class="form-control aichat-input" id="aichat-input"
                                  placeholder="Ask about FX research..." rows="2"
                                  style="resize:none;"></textarea>
                        <button class="btn btn-primary aichat-send-btn" id="aichat-send">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- References panel -->
            <div class="aichat-refs-panel d-flex flex-column" style="width:320px;flex-shrink:0;">
                <div class="aichat-refs-header px-3 py-2">
                    <i class="fa-solid fa-book-open me-1"></i>
                    <span class="fw-semibold small">References</span>
                    <span class="badge bg-secondary ms-2" id="aichat-refs-count">0</span>
                </div>
                <div class="aichat-refs-list overflow-auto flex-fill p-2" id="aichat-refs-list">
                    <div class="text-muted small text-center mt-4">References will appear here after your first query.</div>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="modal fade" id="auroraModal" tabindex="-1" aria-labelledby="auroraModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content aurora-modal-content">
            <div class="modal-header aurora-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="aurora-logo">✦</span>
                    <h5 class="modal-title mb-0" id="auroraModalLabel">Aurora Trading</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Customer info -->
                <div class="aurora-customer-info mb-3">
                    <div class="text-muted small mb-1">Trading for</div>
                    <div class="fw-semibold" id="auroraCustomerName">—</div>
                    <div class="small text-muted mt-1">
                        <span id="auroraPair">AUD/USD</span> &nbsp;·&nbsp;
                        AI signal: <span id="auroraSignal" class="fw-semibold">—</span>
                    </div>
                </div>

                <!-- Live rate display -->
                <div class="aurora-rate-row mb-3">
                    <div class="aurora-rate-side aurora-sell-side">
                        <div class="aurora-rate-label">SELL</div>
                        <div class="aurora-rate-value" id="auroraSellRate">—</div>
                    </div>
                    <div class="aurora-rate-middle">
                        <i class="fa-solid fa-arrow-right-arrow-left text-muted"></i>
                    </div>
                    <div class="aurora-rate-side aurora-buy-side">
                        <div class="aurora-rate-label">BUY</div>
                        <div class="aurora-rate-value" id="auroraBuyRate">—</div>
                    </div>
                </div>

                <!-- Account selector -->
                <div class="mb-3">
                    <label class="form-label small fw-semibold">CRM Account</label>
                    <select class="form-select form-select-sm" id="auroraAccountSelect">
                        <option value="">Loading accounts…</option>
                    </select>
                </div>

                <!-- Lots input -->
                <div class="mb-2">
                    <label class="form-label small fw-semibold">Volume (Lots)</label>
                    <input type="number" class="form-control form-control-sm" id="auroraLotsInput"
                           value="0.10" min="0.01" max="100" step="0.01"
                           oninput="updateAuroraMargin()">
                    <div class="d-flex gap-1 mt-2 flex-wrap">
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setAuroraLots(0.01)">0.01</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setAuroraLots(0.10)">0.10</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setAuroraLots(0.50)">0.50</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setAuroraLots(1.00)">1.00</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setAuroraLots(5.00)">5.00</button>
                    </div>
                </div>
                <div class="text-muted small mb-3" id="auroraMarginInfo">Est. notional: —</div>

                <!-- Result message -->
                <div id="auroraResultMsg" class="alert d-none mb-3" role="alert"></div>

                <!-- Trade buttons -->
                <div class="d-flex gap-2">
                    <button type="button" class="btn aurora-btn-buy flex-fill" id="auroraBuyBtn" onclick="executeAurora('Buy')">
                        <i class="fa-solid fa-arrow-trend-up me-1"></i> BUY
                    </button>
                    <button type="button" class="btn aurora-btn-sell flex-fill" id="auroraSellBtn" onclick="executeAurora('Sell')">
                        <i class="fa-solid fa-arrow-trend-down me-1"></i> SELL
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
.btn-aurora {
    background: linear-gradient(135deg, #2d1b69, #0f3460);
    color: #c084fc;
    border: 1px solid #7c3aed;
    font-weight: 600;
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 4px;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
}
.btn-aurora:hover { 
    background: linear-gradient(135deg, #4c1d95, #1e3a5f); 
    color: #e9d5ff;
    text-decoration: none;
}
.aurora-modal-content { background: #0f0f1a; color: #e2e8f0; border: 1px solid #4c1d95; border-radius: 12px; }
.aurora-header { background: linear-gradient(135deg, #1e1b4b, #0f3460); border-bottom: 1px solid #4c1d95; border-radius: 12px 12px 0 0; }
.aurora-logo { font-size: 1.4rem; color: #c084fc; }
.aurora-customer-info { background: #1a1a2e; border: 1px solid #2d2d4e; border-radius: 8px; padding: 10px 14px; }
.aurora-rate-row { display: flex; gap: 8px; align-items: center; }
.aurora-rate-side { flex: 1; text-align: center; padding: 10px; border-radius: 8px; }
.aurora-sell-side { background: #2d0e0e; border: 1px solid #7f1d1d; }
.aurora-buy-side  { background: #0e2d14; border: 1px solid #14532d; }
.aurora-rate-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 4px; }
.aurora-sell-side .aurora-rate-label { color: #fca5a5; }
.aurora-buy-side  .aurora-rate-label { color: #86efac; }
.aurora-rate-value { font-size: 1.35rem; font-weight: 800; font-family: monospace; }
.aurora-sell-side .aurora-rate-value { color: #f87171; }
.aurora-buy-side  .aurora-rate-value { color: #4ade80; }
.aurora-rate-middle { color: #6b7280; }
.aurora-btn-buy  { background: #15803d; color: #fff; font-weight: 700; border: none; }
.aurora-btn-buy:hover  { background: #166534; color: #fff; }
.aurora-btn-sell { background: #b91c1c; color: #fff; font-weight: 700; border: none; }
.aurora-btn-sell:hover { background: #991b1b; color: #fff; }
.aurora-btn-buy:disabled, .aurora-btn-sell:disabled { opacity: 0.45; cursor: not-allowed; }
#auroraModal .form-select, #auroraModal .form-control { background: #1a1a2e; color: #e2e8f0; border-color: #4c1d95; }
#auroraModal .form-select option { background: #1a1a2e; }
#auroraModal label { color: #a5b4fc; }
</style>
<script>
(function () {
    const ORORA_QUOTE = '@Model.AuroraQuoteUrl';

    let auroraRateInterval = null;

    window.openAurora = function (customerName, pair, signal) {
        document.getElementById('auroraCustomerName').textContent = customerName;
        document.getElementById('auroraPair').textContent = pair;

        var sigEl = document.getElementById('auroraSignal');
        sigEl.textContent = signal;
        sigEl.className = 'fw-semibold ' + (signal === 'Buy' ? 'text-success' : 'text-danger');

        document.getElementById('auroraLotsInput').value = '0.10';
        document.getElementById('auroraResultMsg').className = 'alert d-none mb-3';
        setBtnsDisabled(false);

        loadAuroraAccounts();
        fetchAuroraRate();

        if (auroraRateInterval) clearInterval(auroraRateInterval);
        auroraRateInterval = setInterval(fetchAuroraRate, 3000);

        var modal = new bootstrap.Modal(document.getElementById('auroraModal'));
        modal.show();

        document.getElementById('auroraModal').addEventListener('hidden.bs.modal', function () {
            if (auroraRateInterval) { clearInterval(auroraRateInterval); auroraRateInterval = null; }
        }, { once: true });
    };

    async function fetchAuroraRate() {
        try {
            var res = await fetch(ORORA_QUOTE);
            if (!res.ok) return;
            var q = await res.json();
            document.getElementById('auroraSellRate').textContent = q.bid.toFixed(4);
            document.getElementById('auroraBuyRate').textContent  = q.ask.toFixed(4);
            updateAuroraMargin(q.mid);
        } catch (_) {}
    }

    async function loadAuroraAccounts() {
        var sel = document.getElementById('auroraAccountSelect');
        sel.innerHTML = '<option value="">Loading…</option>';
        try {
            var res = await fetch(ORORA_API + '/accounts');
            if (!res.ok) { sel.innerHTML = '<option value="">Failed to load</option>'; return; }
            var accounts = await res.json();
            sel.innerHTML = accounts.map(function (a) {
                return '<option value="' + a.id + '">' + a.customerName + ' (' + a.accountNumber + ')</option>';
            }).join('');
            if (accounts.length > 0) sel.value = accounts[0].id;
        } catch (_) {
            sel.innerHTML = '<option value="1">Default Account</option>';
        }
    }

    window.updateAuroraMargin = function (mid) {
        var lots  = parseFloat(document.getElementById('auroraLotsInput').value) || 0;
        var price = mid || parseFloat(document.getElementById('auroraBuyRate').textContent) || 0.655;
        var notional = Math.round(lots * 100000 * price);
        document.getElementById('auroraMarginInfo').textContent =
            notional > 0 ? 'Est. notional: $' + notional.toLocaleString() + ' AUD' : 'Est. notional: —';
    };

    window.setAuroraLots = function (v) {
        document.getElementById('auroraLotsInput').value = v.toFixed(2);
        updateAuroraMargin();
    };

    function setBtnsDisabled(disabled) {
        document.getElementById('auroraBuyBtn').disabled  = disabled;
        document.getElementById('auroraSellBtn').disabled = disabled;
    }

    window.executeAurora = async function (direction) {
        var lots      = parseFloat(document.getElementById('auroraLotsInput').value);
        var accountId = parseInt(document.getElementById('auroraAccountSelect').value) || 1;
        var customer  = document.getElementById('auroraCustomerName').textContent;
        var pair      = document.getElementById('auroraPair').textContent;

        if (!lots || lots <= 0) {
            showAuroraMsg('Please enter a valid lot size.', false);
            return;
        }

        setBtnsDisabled(true);
        showAuroraMsg('Executing trade via Aurora…', null);

        try {
            var res = await fetch(ORORA_API + '/trade', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    direction: direction,
                    currencyPair: pair,
                    lots: lots,
                    accountId: accountId,
                    customerName: customer
                })
            });
            var data = await res.json();
            if (data.success) {
                var rate = data.rate ? data.rate.toFixed(4) : '—';
                showAuroraMsg('✓ ' + direction + ' ' + lots + ' lots ' + pair + ' executed at ' + rate + '. Tx: ' + data.transactionId, true);
            } else {
                showAuroraMsg('✗ Trade failed: ' + data.message, false);
                setBtnsDisabled(false);
            }
        } catch (err) {
            showAuroraMsg('✗ Connection error: ' + err.message, false);
            setBtnsDisabled(false);
        }
    };

    function showAuroraMsg(text, success) {
        var el = document.getElementById('auroraResultMsg');
        if (success === null) {
            el.className = 'alert alert-secondary mb-3';
        } else {
            el.className = success ? 'alert alert-success mb-3' : 'alert alert-danger mb-3';
        }
        el.textContent = text;
    }
})();
</script>
<style>
.aichat-settings {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
}
.aichat-panel {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
}
.aichat-messages {
    background: #f8f9fa;
}
.aichat-welcome {
    text-align: center;
    padding: 60px 20px 20px;
    color: #6c757d;
}
.aichat-msg {
    margin-bottom: 14px;
}
.aichat-msg-user .aichat-bubble {
    background: #1a3a5c;
    color: #fff;
    border-radius: 12px 12px 4px 12px;
    padding: 10px 14px;
    max-width: 85%;
    margin-left: auto;
    font-size: 0.9rem;
}
.aichat-msg-assistant .aichat-bubble {
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 12px 12px 12px 4px;
    padding: 10px 14px;
    max-width: 90%;
    font-size: 0.9rem;
    white-space: pre-wrap;
}
.aichat-meta {
    font-size: 0.72rem;
    color: #adb5bd;
    margin-top: 3px;
}
.aichat-msg-user .aichat-meta { text-align: right; }
.aichat-composer {
    border-top: 1px solid #dee2e6;
    background: #fff;
}
.aichat-input:focus { box-shadow: none; border-color: #1a3a5c; }
.aichat-send-btn { background: #1a3a5c; border: none; }
.aichat-send-btn:hover { background: #0f2540; }
.aichat-refs-panel {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
}
.aichat-refs-header {
    background: #1a3a5c;
    color: #fff;
    border-radius: 8px 8px 0 0;
}
.aichat-ref-card {
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 10px 12px;
    margin-bottom: 8px;
    font-size: 0.82rem;
    transition: border-color 0.15s;
}
.aichat-ref-card:hover { border-color: #1a3a5c; }
.aichat-ref-card a { color: #1a3a5c; font-weight: 600; text-decoration: none; }
.aichat-ref-card a:hover { text-decoration: underline; }
.aichat-typing .aichat-bubble {
    font-style: italic;
    color: #6c757d;
}
.aichat-select { font-size: 0.82rem; }
.aichat-temp-slider { cursor: pointer; }
</style>
<script>
(function () {
    const messagesEl = document.getElementById('aichat-messages');
    const inputEl    = document.getElementById('aichat-input');
    const sendBtn    = document.getElementById('aichat-send');
    const clearBtn   = document.getElementById('aichat-clear');
    const tempSlider = document.getElementById('aichat-temp');
    const tempLabel  = document.getElementById('aichat-temp-label');
    const refsEl     = document.getElementById('aichat-refs-list');
    const refsCount  = document.getElementById('aichat-refs-count');

    tempSlider.addEventListener('input', () => { tempLabel.textContent = parseFloat(tempSlider.value).toFixed(2); });

    var history = [];

    function appendMsg(role, text) {
        var welcome = messagesEl.querySelector('.aichat-welcome');
        if (welcome) welcome.remove();

        var now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        var div = document.createElement('div');
        div.className = 'aichat-msg aichat-msg-' + role;
        div.innerHTML =
            '<div class="aichat-bubble">' + escHtml(text) + '</div>' +
            '<div class="aichat-meta">' + (role === 'user' ? 'You' : 'AI') + ' · ' + now + '</div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return div;
    }

    function appendTyping() {
        var div = document.createElement('div');
        div.className = 'aichat-msg aichat-msg-assistant aichat-typing';
        div.innerHTML = '<div class="aichat-bubble">Thinking…</div>';
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return div;
    }

    function renderRefs(refs) {
        refsCount.textContent = refs.length;
        if (!refs.length) {
            refsEl.innerHTML = '<div class="text-muted small text-center mt-4">No matching articles found for this query.</div>';
            return;
        }
        refsEl.innerHTML = refs.map(function (r, i) {
            var sentClass = r.sentiment === 'Bullish' ? 'sentiment-bullish' : r.sentiment === 'Bearish' ? 'sentiment-bearish' : 'sentiment-neutral';
            return '<div class="aichat-ref-card">' +
                '<div class="d-flex justify-content-between align-items-start mb-1">' +
                '<span class="cat-badge cat-' + r.category.replace(/\//g,'-').replace(/ /g,'-').toLowerCase() + '">' + escHtml(r.category) + '</span>' +
                '<span class="sentiment-badge ' + sentClass + '">' + escHtml(r.sentiment) + '</span>' +
                '</div>' +
                '<a href="' + r.url + '" target="_blank">[' + (i+1) + '] ' + escHtml(r.title) + '</a>' +
                '<p class="text-muted mb-1 mt-1" style="font-size:0.78rem;">' + escHtml(r.summary.substring(0, 90)) + '…</p>' +
                '<div class="text-muted" style="font-size:0.72rem;">' + escHtml(r.author) + ' · ' + escHtml(r.publishedDate) + '</div>' +
                '</div>';
        }).join('');
    }

    async function send() {
        var text = inputEl.value.trim();
        if (!text) return;
        inputEl.value = '';
        sendBtn.disabled = true;

        appendMsg('user', text);
        var typing = appendTyping();

        history.push({ role: 'user', content: text });

        try {
            var res = await fetch('/api/chat/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: text,
                    temperature: parseFloat(tempSlider.value),
                    history: history.slice(-10)
                })
            });
            var data = await res.json();
            typing.remove();
            appendMsg('assistant', data.response);
            history.push({ role: 'assistant', content: data.response });
            renderRefs(data.references || []);
        } catch (e) {
            typing.remove();
            appendMsg('assistant', 'Request failed. Please try again.');
        }
        sendBtn.disabled = false;
    }

    sendBtn.addEventListener('click', send);
    inputEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });

    clearBtn.addEventListener('click', function () {
        history = [];
        messagesEl.innerHTML = '<div class="aichat-welcome"><i class="fa-solid fa-brain fa-2x mb-2"></i><p class="mb-1 fw-semibold">Research AI Assistant</p><p class="small text-muted">Ask about market conditions, currency pairs, or trading strategy.</p></div>';
        refsEl.innerHTML = '<div class="text-muted small text-center mt-4">References will appear here after your first query.</div>';
        refsCount.textContent = '0';
    });

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
})();
</script>
}
