@page
@model FxWebPortal.Pages.Account.IndexModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "My Account";
    ViewData["DisplayName"] = Model.DisplayName;
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Profile header -->
<div class="account-profile-header mb-4">
    <div class="d-flex align-items-center gap-3">
        <div class="account-avatar">
            <i class="fa-solid fa-circle-user"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold">@Model.DisplayName</h4>
            <div class="text-muted small mt-1">
                Interests:
                @foreach (var interest in Model.Interests)
                {
                    <span class="cat-badge cat-@(interest.Replace("/","-").Replace(" ","-").ToLower()) me-1">@interest</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs account-tabs mb-4" id="accountTabs">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-insights">
            <i class="fa-solid fa-chart-line me-1"></i> Market Insights
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-suggestions">
            <i class="fa-solid fa-robot me-1"></i> Suggest Customer
        </button>
    </li>
</ul>

<div class="tab-content">

    <!-- ── Tab 1: Market Insights ── -->
    <div class="tab-pane fade show active" id="tab-insights">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">Market Insights</h5>
                <p class="text-muted small mb-0 mt-1">Research filtered to your interests: <strong>@string.Join(", ", Model.Interests)</strong></p>
            </div>
            <span class="badge bg-danger fs-6">@Model.MarketInsights.Count articles</span>
        </div>

        @if (Model.MarketInsights.Any())
        {
            <div class="row g-4">
                @foreach (var article in Model.MarketInsights)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="article-card h-100">
                            <div class="article-card-header">
                                <span class="cat-badge cat-@(article.Category.Replace("/","-").Replace(" ","-").ToLower())">@article.Category</span>
                                <span class="sentiment-badge sentiment-@article.Sentiment.ToLower()">@article.Sentiment</span>
                            </div>
                            <div class="article-card-body">
                                <h2 class="article-title">
                                    <a href="/Article?id=@article.Id" target="_blank">@article.Title</a>
                                </h2>
                                <p class="article-summary">@article.Summary</p>
                            </div>
                            <div class="article-card-footer">
                                <span class="article-author">@article.Author</span>
                                <span class="article-date">@article.PublishedDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fa-solid fa-newspaper fa-2x mb-3 d-block"></i>
                No published articles match your interests yet. Check back soon.
            </div>
        }
    </div>

    <!-- ── Tab 2: Suggest Customer ── -->
    <div class="tab-pane fade" id="tab-suggestions">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="mb-0">AI-Suggested Customer Prospects</h5>
                <p class="text-muted small mb-0 mt-1">Prospects matching your interest in <strong>@string.Join(", ", Model.Interests)</strong></p>
            </div>
            <span class="badge bg-danger fs-6">@Model.Suggestions.Count</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Company</th>
                        <th>Pair</th>
                        <th>Direction</th>
                        <th>Confidence</th>
                        <th>Analysis</th>
                        <th>Received</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Suggestions)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@s.CustomerName</div>
                                <div class="text-muted small">@s.Email</div>
                            </td>
                            <td>@s.Company</td>
                            <td><span class="cat-badge cat-aud-usd">@s.CurrencyPair</span></td>
                            <td>
                                @if (s.Direction == "Buy")
                                {
                                    <span class="sentiment-badge sentiment-bullish">▲ Buy</span>
                                }
                                else
                                {
                                    <span class="sentiment-badge sentiment-bearish">▼ Sell</span>
                                }
                            </td>
                            <td>
                                @if (s.Confidence == "High")
                                {
                                    <span class="badge bg-success">High</span>
                                }
                                else if (s.Confidence == "Medium")
                                {
                                    <span class="badge bg-warning text-dark">Medium</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Low</span>
                                }
                            </td>
                            <td class="suggestion-analysis" title="@s.Analysis">
                                @TextHelper.Truncate(s.Analysis, 90)
                            </td>
                            <td class="text-muted small">@s.ReceivedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="d-flex gap-1 flex-wrap">
                                <a href="tel:@s.Phone" class="btn btn-xs btn-outline-success" title="Call @s.CustomerName at @s.Phone">
                                    📞 Call
                                </a>
                                <form method="post" asp-page-handler="SendSuggestionToBroker" asp-route-id="@s.Id" style="display:inline">
                                    <button class="btn btn-xs btn-outline-primary" type="submit"
                                            title="Push this prospect to Broker CRM">
                                        ⚡ Action
                                    </button>
                                </form>
                                <button class="btn btn-xs btn-orora"
                                        onclick="openOrora('@s.CustomerName', '@s.CurrencyPair', '@s.Direction')"
                                        title="Open Orora to trade for @s.CustomerName">
                                    ✦ Orora
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Suggestions.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No suggestions matching your interests yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- ── Orora Trading Popup ── -->
<div class="modal fade" id="ororaModal" tabindex="-1" aria-labelledby="ororaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content orora-modal-content">
            <div class="modal-header orora-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="orora-logo">✦</span>
                    <h5 class="modal-title mb-0" id="ororaModalLabel">Orora Trading</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Customer info -->
                <div class="orora-customer-info mb-3">
                    <div class="text-muted small mb-1">Trading for</div>
                    <div class="fw-semibold" id="ororaCustomerName">—</div>
                    <div class="small text-muted mt-1">
                        <span id="ororaPair">AUD/USD</span> &nbsp;·&nbsp;
                        AI signal: <span id="ororaSignal" class="fw-semibold">—</span>
                    </div>
                </div>

                <!-- Live rate display -->
                <div class="orora-rate-row mb-3">
                    <div class="orora-rate-side orora-sell-side">
                        <div class="orora-rate-label">SELL</div>
                        <div class="orora-rate-value" id="ororaSellRate">—</div>
                    </div>
                    <div class="orora-rate-middle">
                        <i class="fa-solid fa-arrow-right-arrow-left text-muted"></i>
                    </div>
                    <div class="orora-rate-side orora-buy-side">
                        <div class="orora-rate-label">BUY</div>
                        <div class="orora-rate-value" id="ororaBuyRate">—</div>
                    </div>
                </div>

                <!-- Account selector -->
                <div class="mb-3">
                    <label class="form-label small fw-semibold">CRM Account</label>
                    <select class="form-select form-select-sm" id="ororaAccountSelect">
                        <option value="">Loading accounts…</option>
                    </select>
                </div>

                <!-- Lots input -->
                <div class="mb-2">
                    <label class="form-label small fw-semibold">Volume (Lots)</label>
                    <input type="number" class="form-control form-control-sm" id="ororaLotsInput"
                           value="0.10" min="0.01" max="100" step="0.01"
                           oninput="updateOroraMargin()">
                    <div class="d-flex gap-1 mt-2 flex-wrap">
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setOroraLots(0.01)">0.01</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setOroraLots(0.10)">0.10</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setOroraLots(0.50)">0.50</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setOroraLots(1.00)">1.00</button>
                        <button type="button" class="btn btn-xs btn-outline-secondary" onclick="setOroraLots(5.00)">5.00</button>
                    </div>
                </div>
                <div class="text-muted small mb-3" id="ororaMarginInfo">Est. notional: —</div>

                <!-- Result message -->
                <div id="ororaResultMsg" class="alert d-none mb-3" role="alert"></div>

                <!-- Trade buttons -->
                <div class="d-flex gap-2">
                    <button type="button" class="btn orora-btn-buy flex-fill" id="ororaBuyBtn" onclick="executeOrora('Buy')">
                        <i class="fa-solid fa-arrow-trend-up me-1"></i> BUY
                    </button>
                    <button type="button" class="btn orora-btn-sell flex-fill" id="ororaSellBtn" onclick="executeOrora('Sell')">
                        <i class="fa-solid fa-arrow-trend-down me-1"></i> SELL
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
.btn-orora {
    background: linear-gradient(135deg, #2d1b69, #0f3460);
    color: #c084fc;
    border: 1px solid #7c3aed;
    font-weight: 600;
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 4px;
    transition: all 0.2s;
}
.btn-orora:hover { background: linear-gradient(135deg, #4c1d95, #1e3a5f); color: #e9d5ff; }
.orora-modal-content { background: #0f0f1a; color: #e2e8f0; border: 1px solid #4c1d95; border-radius: 12px; }
.orora-header { background: linear-gradient(135deg, #1e1b4b, #0f3460); border-bottom: 1px solid #4c1d95; border-radius: 12px 12px 0 0; }
.orora-logo { font-size: 1.4rem; color: #c084fc; }
.orora-customer-info { background: #1a1a2e; border: 1px solid #2d2d4e; border-radius: 8px; padding: 10px 14px; }
.orora-rate-row { display: flex; gap: 8px; align-items: center; }
.orora-rate-side { flex: 1; text-align: center; padding: 10px; border-radius: 8px; }
.orora-sell-side { background: #2d0e0e; border: 1px solid #7f1d1d; }
.orora-buy-side  { background: #0e2d14; border: 1px solid #14532d; }
.orora-rate-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 4px; }
.orora-sell-side .orora-rate-label { color: #fca5a5; }
.orora-buy-side  .orora-rate-label { color: #86efac; }
.orora-rate-value { font-size: 1.35rem; font-weight: 800; font-family: monospace; }
.orora-sell-side .orora-rate-value { color: #f87171; }
.orora-buy-side  .orora-rate-value { color: #4ade80; }
.orora-rate-middle { color: #6b7280; }
.orora-btn-buy  { background: #15803d; color: #fff; font-weight: 700; border: none; }
.orora-btn-buy:hover  { background: #166534; color: #fff; }
.orora-btn-sell { background: #b91c1c; color: #fff; font-weight: 700; border: none; }
.orora-btn-sell:hover { background: #991b1b; color: #fff; }
.orora-btn-buy:disabled, .orora-btn-sell:disabled { opacity: 0.45; cursor: not-allowed; }
#ororaModal .form-select, #ororaModal .form-control { background: #1a1a2e; color: #e2e8f0; border-color: #4c1d95; }
#ororaModal .form-select option { background: #1a1a2e; }
#ororaModal label { color: #a5b4fc; }
</style>
<script>
(function () {
    const ORORA_API   = '@Model.OroraApiUrl';
    const ORORA_QUOTE = '@Model.OroraQuoteUrl';

    let ororaRateInterval = null;

    window.openOrora = function (customerName, pair, signal) {
        document.getElementById('ororaCustomerName').textContent = customerName;
        document.getElementById('ororaPair').textContent = pair;

        var sigEl = document.getElementById('ororaSignal');
        sigEl.textContent = signal;
        sigEl.className = 'fw-semibold ' + (signal === 'Buy' ? 'text-success' : 'text-danger');

        document.getElementById('ororaLotsInput').value = '0.10';
        document.getElementById('ororaResultMsg').className = 'alert d-none mb-3';
        setBtnsDisabled(false);

        loadOroraAccounts();
        fetchOroraRate();

        if (ororaRateInterval) clearInterval(ororaRateInterval);
        ororaRateInterval = setInterval(fetchOroraRate, 3000);

        var modal = new bootstrap.Modal(document.getElementById('ororaModal'));
        modal.show();

        document.getElementById('ororaModal').addEventListener('hidden.bs.modal', function () {
            if (ororaRateInterval) { clearInterval(ororaRateInterval); ororaRateInterval = null; }
        }, { once: true });
    };

    async function fetchOroraRate() {
        try {
            var res = await fetch(ORORA_QUOTE);
            if (!res.ok) return;
            var q = await res.json();
            document.getElementById('ororaSellRate').textContent = q.bid.toFixed(4);
            document.getElementById('ororaBuyRate').textContent  = q.ask.toFixed(4);
            updateOroraMargin(q.mid);
        } catch (_) {}
    }

    async function loadOroraAccounts() {
        var sel = document.getElementById('ororaAccountSelect');
        sel.innerHTML = '<option value="">Loading…</option>';
        try {
            var res = await fetch(ORORA_API + '/accounts');
            if (!res.ok) { sel.innerHTML = '<option value="">Failed to load</option>'; return; }
            var accounts = await res.json();
            sel.innerHTML = accounts.map(function (a) {
                return '<option value="' + a.id + '">' + a.customerName + ' (' + a.accountNumber + ')</option>';
            }).join('');
            if (accounts.length > 0) sel.value = accounts[0].id;
        } catch (_) {
            sel.innerHTML = '<option value="1">Default Account</option>';
        }
    }

    window.updateOroraMargin = function (mid) {
        var lots  = parseFloat(document.getElementById('ororaLotsInput').value) || 0;
        var price = mid || parseFloat(document.getElementById('ororaBuyRate').textContent) || 0.655;
        var notional = Math.round(lots * 100000 * price);
        document.getElementById('ororaMarginInfo').textContent =
            notional > 0 ? 'Est. notional: $' + notional.toLocaleString() + ' AUD' : 'Est. notional: —';
    };

    window.setOroraLots = function (v) {
        document.getElementById('ororaLotsInput').value = v.toFixed(2);
        updateOroraMargin();
    };

    function setBtnsDisabled(disabled) {
        document.getElementById('ororaBuyBtn').disabled  = disabled;
        document.getElementById('ororaSellBtn').disabled = disabled;
    }

    window.executeOrora = async function (direction) {
        var lots      = parseFloat(document.getElementById('ororaLotsInput').value);
        var accountId = parseInt(document.getElementById('ororaAccountSelect').value) || 1;
        var customer  = document.getElementById('ororaCustomerName').textContent;
        var pair      = document.getElementById('ororaPair').textContent;

        if (!lots || lots <= 0) {
            showOroraMsg('Please enter a valid lot size.', false);
            return;
        }

        setBtnsDisabled(true);
        showOroraMsg('Executing trade via Orora…', null);

        try {
            var res = await fetch(ORORA_API + '/trade', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    direction: direction,
                    currencyPair: pair,
                    lots: lots,
                    accountId: accountId,
                    customerName: customer
                })
            });
            var data = await res.json();
            if (data.success) {
                var rate = data.rate ? data.rate.toFixed(4) : '—';
                showOroraMsg('✓ ' + direction + ' ' + lots + ' lots ' + pair + ' executed at ' + rate + '. Tx: ' + data.transactionId, true);
            } else {
                showOroraMsg('✗ Trade failed: ' + data.message, false);
                setBtnsDisabled(false);
            }
        } catch (err) {
            showOroraMsg('✗ Connection error: ' + err.message, false);
            setBtnsDisabled(false);
        }
    };

    function showOroraMsg(text, success) {
        var el = document.getElementById('ororaResultMsg');
        if (success === null) {
            el.className = 'alert alert-secondary mb-3';
        } else {
            el.className = success ? 'alert alert-success mb-3' : 'alert alert-danger mb-3';
        }
        el.textContent = text;
    }
})();
</script>
}
