@page
@model FxWebPortal.Pages.Account.AuroraWorkflowModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aurora – FX Trading</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        :root {
            --bg: #0c1017;
            --panel: #141b26;
            --panel2: #1a2333;
            --border: #242f42;
            --border2: #2d3a52;
            --text: #d8e4f2;
            --text-muted: #5f7591;
            --text-dim: #3d5070;
            --green: #00c97a;
            --green-dim: rgba(0,201,122,0.15);
            --red: #ff4f5e;
            --red-dim: rgba(255,79,94,0.15);
            --gold: #c8a84b;
            --gold-dim: rgba(200,168,75,0.15);
            --blue: #4a90d9;
            --teal: #00b8c8;
            --accent: #7eb3ff;
            --filled: #00c97a;
            --working: #f5a623;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; overflow: hidden; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, sans-serif;
            font-size: 12px;
            display: flex;
            flex-direction: column;
        }

        /* ── TOP NAV ── */
        .top-nav {
            background: #111820;
            border-bottom: 1px solid var(--border);
            height: 38px;
            display: flex;
            align-items: stretch;
            flex-shrink: 0;
            padding: 0 12px;
            gap: 0;
        }
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-right: 20px;
            border-right: 1px solid var(--border);
            margin-right: 8px;
        }
        .nav-brand-mq {
            font-size: 13px;
            font-weight: 700;
            color: white;
            letter-spacing: 0.5px;
        }
        .nav-brand-sep {
            color: var(--border2);
            font-size: 16px;
            font-weight: 200;
        }
        .nav-brand-aurora {
            font-size: 14px;
            font-weight: 300;
            color: var(--gold);
            letter-spacing: 2px;
        }
        .nav-tabs-list {
            display: flex;
            align-items: stretch;
            list-style: none;
            gap: 0;
            flex: 1;
        }
        .nav-tab {
            display: flex;
            align-items: center;
            padding: 0 16px;
            font-size: 11.5px;
            font-weight: 500;
            color: var(--text-muted);
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.15s;
            letter-spacing: 0.2px;
            white-space: nowrap;
        }
        .nav-tab:hover { color: var(--text); }
        .nav-tab.active {
            color: white;
            border-bottom-color: var(--gold);
            background: rgba(200,168,75,0.06);
        }
        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-left: 12px;
            border-left: 1px solid var(--border);
        }
        .account-label {
            font-size: 10px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }
        .btn-back-nav {
            font-size: 11px;
            color: var(--text-muted);
            background: none;
            border: 1px solid var(--border2);
            border-radius: 3px;
            padding: 3px 10px;
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-back-nav:hover { color: var(--text); border-color: var(--text-muted); }

        /* ── SECTION HEADERS ── */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 28px;
            padding: 0 12px;
            background: #0f1520;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .section-title {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .section-actions {
            display: flex;
            gap: 6px;
            align-items: center;
        }
        .section-btn {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            background: none;
            border: 1px solid var(--border2);
            border-radius: 2px;
            padding: 2px 8px;
            cursor: pointer;
            transition: all 0.15s;
            text-transform: uppercase;
        }
        .section-btn:hover { color: var(--text); border-color: var(--text-muted); }
        .section-btn.active {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
        }

        /* ── MAIN LAYOUT ── */
        .main-layout {
            flex: 1;
            display: flex;
            overflow: hidden;
            min-height: 0;
        }

        /* ── LEFT: PRICES ── */
        .prices-panel {
            display: flex;
            flex-direction: column;
            width: 340px;
            flex-shrink: 0;
            border-right: 1px solid var(--border);
            overflow: hidden;
        }
        .tile-grid {
            flex: 1;
            padding: 10px;
            overflow-y: auto;
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
        }
        .tile-grid::-webkit-scrollbar { width: 4px; }
        .tile-grid::-webkit-scrollbar-track { background: transparent; }
        .tile-grid::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

        /* ── CURRENCY TILE ── */
        .fx-tile {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            cursor: pointer;
            transition: border-color 0.15s;
        }
        .fx-tile:hover { border-color: var(--border2); }
        .fx-tile.active { border-color: var(--gold); }
        .tile-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 5px 8px;
            background: var(--panel2);
            border-bottom: 1px solid var(--border);
        }
        .tile-pair {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11.5px;
            font-weight: 700;
            color: white;
        }
        .flag-stack {
            position: relative;
            width: 22px;
            height: 14px;
        }
        .flag {
            width: 14px;
            height: 10px;
            border-radius: 1px;
            position: absolute;
            font-size: 12px;
            line-height: 1;
        }
        .flag1 { top: 0; left: 0; }
        .flag2 { bottom: 0; right: 0; }
        .tile-type {
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            margin-left: 4px;
        }
        .tile-actions {
            display: flex;
            gap: 4px;
        }
        .tile-btn {
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.5px;
            padding: 2px 6px;
            border-radius: 2px;
            border: 1px solid var(--border2);
            background: none;
            color: var(--text-muted);
            cursor: pointer;
            text-transform: uppercase;
        }
        .tile-btn:hover { border-color: var(--gold); color: var(--gold); }
        .tile-prices {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            text-align: center;
            padding: 6px 0 4px;
        }
        .tile-sell-label, .tile-buy-label {
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 3px;
        }
        .tile-center { font-size: 9px; color: var(--text-muted); }
        .tile-mid-rate {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
        }
        .tile-sell {
            padding: 4px 6px;
            border-right: 1px solid var(--border);
        }
        .tile-sell:hover { background: var(--red-dim); }
        .tile-buy {
            padding: 4px 6px;
            border-left: 1px solid var(--border);
        }
        .tile-buy:hover { background: var(--green-dim); }
        .tile-mid { padding: 4px 6px; }
        .sell-price, .buy-price {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 1px;
        }
        .price-main {
            font-size: 20px;
            font-weight: 700;
            line-height: 1;
        }
        .price-pips {
            font-size: 10px;
            font-weight: 700;
            line-height: 1;
            align-self: flex-start;
            margin-top: 2px;
        }
        .tile-sell .price-main, .tile-sell .price-pips { color: var(--red); }
        .tile-buy .price-main, .tile-buy .price-pips { color: var(--green); }
        .tile-spread {
            font-size: 9px;
            color: var(--text-muted);
            margin-top: 2px;
        }
        .tile-tenors {
            display: flex;
            justify-content: space-between;
            padding: 4px 8px;
            border-top: 1px solid var(--border);
            background: rgba(0,0,0,0.15);
        }
        .tenor-btn {
            font-size: 9px;
            font-weight: 600;
            color: var(--text-dim);
            cursor: pointer;
            padding: 1px 3px;
            border-radius: 2px;
            border: none;
            background: none;
            transition: color 0.1s;
        }
        .tenor-btn:hover { color: var(--accent); }
        .tenor-btn.active { color: var(--gold); }
        .tile-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 5px 8px;
            border-top: 1px solid var(--border);
        }
        .tile-qty {
            font-size: 10px;
            color: var(--text-muted);
        }
        .tile-qty strong { color: var(--text); }
        .tile-order-btn {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.8px;
            color: white;
            background: var(--panel2);
            border: 1px solid var(--border2);
            border-radius: 2px;
            padding: 3px 14px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.15s;
        }
        .tile-order-btn:hover {
            background: var(--gold-dim);
            border-color: var(--gold);
            color: var(--gold);
        }

        /* ── CENTER: ORDER TICKET ── */
        .order-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .order-content {
            flex: 1;
            padding: 14px 16px;
            overflow-y: auto;
        }
        .order-content::-webkit-scrollbar { width: 4px; }
        .order-content::-webkit-scrollbar-track { background: transparent; }
        .order-content::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

        /* Order ticket card */
        .order-ticket {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
            max-width: 440px;
        }
        .ticket-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 14px;
            background: var(--panel2);
            border-bottom: 1px solid var(--border);
        }
        .ticket-pair {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 700;
            color: white;
        }
        .ticket-status {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.6px;
            padding: 2px 8px;
            border-radius: 2px;
        }
        .ticket-status.pending {
            background: var(--gold-dim);
            border: 1px solid var(--gold);
            color: var(--gold);
        }
        .ticket-status.executing {
            background: rgba(74,144,217,0.15);
            border: 1px solid var(--blue);
            color: var(--blue);
        }
        .ticket-status.filled {
            background: var(--green-dim);
            border: 1px solid var(--green);
            color: var(--green);
        }

        .ticket-body { padding: 14px; }
        .field-row {
            display: grid;
            grid-template-columns: 120px 1fr;
            align-items: center;
            margin-bottom: 10px;
            gap: 8px;
        }
        .field-label {
            font-size: 10.5px;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.3px;
        }
        .field-value {
            font-size: 11px;
            color: var(--text);
        }

        /* toggle group */
        .toggle-group {
            display: flex;
            border: 1px solid var(--border2);
            border-radius: 3px;
            overflow: hidden;
        }
        .toggle-btn {
            flex: 1;
            padding: 5px 12px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-align: center;
            cursor: pointer;
            border: none;
            background: none;
            color: var(--text-muted);
            transition: all 0.15s;
            text-transform: uppercase;
        }
        .toggle-btn + .toggle-btn { border-left: 1px solid var(--border2); }
        .toggle-btn.buy.active { background: var(--green); color: #000; }
        .toggle-btn.sell.active { background: var(--red); color: #fff; }
        .toggle-btn.active { background: var(--gold); color: #000; }

        /* select / input */
        .ticket-select, .ticket-input {
            width: 100%;
            background: var(--panel2);
            border: 1px solid var(--border2);
            border-radius: 3px;
            color: var(--text);
            font-size: 11px;
            padding: 5px 10px;
            outline: none;
            transition: border-color 0.15s;
            height: 28px;
        }
        .ticket-select:focus, .ticket-input:focus { border-color: var(--gold); }
        .ticket-input-large {
            font-size: 15px;
            font-weight: 700;
            background: var(--panel2);
            border: 1px solid var(--border2);
            border-radius: 3px;
            color: white;
            padding: 6px 10px;
            width: 100%;
            outline: none;
            height: 34px;
        }
        .ticket-input-large:focus { border-color: var(--gold); }

        .mkt-price-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .mkt-price-val {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }
        .mkt-price-pip {
            font-size: 10px;
            font-weight: 600;
            padding: 1px 6px;
            border-radius: 2px;
        }
        .mkt-price-pip.pos { color: var(--green); background: var(--green-dim); }
        .mkt-price-pip.neg { color: var(--red); background: var(--red-dim); }
        .mkt-price-warn {
            font-size: 9.5px;
            color: var(--red);
        }

        .ticket-divider {
            height: 1px;
            background: var(--border);
            margin: 12px 0;
        }
        .field-group-label {
            font-size: 9.5px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 10px;
        }

        .ticket-footer {
            display: flex;
            gap: 8px;
            padding: 12px 14px;
            border-top: 1px solid var(--border);
            background: var(--panel2);
        }
        .btn-ticket {
            padding: 7px 20px;
            border-radius: 3px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            border: none;
            transition: all 0.15s;
        }
        .btn-ticket:disabled { opacity: 0.4; cursor: not-allowed; }
        .btn-reset {
            background: none;
            border: 1px solid var(--border2);
            color: var(--text-muted);
        }
        .btn-reset:hover { border-color: var(--text-muted); color: var(--text); }
        .btn-clone {
            background: none;
            border: 1px solid var(--border2);
            color: var(--text-muted);
        }
        .btn-clone:hover { border-color: var(--accent); color: var(--accent); }
        .btn-submit {
            flex: 1;
            background: var(--gold);
            color: #000;
            font-size: 12px;
        }
        .btn-submit:hover:not(:disabled) { background: #d4b35c; }
        .btn-submit.buy-mode { background: var(--green); color: #000; }
        .btn-submit.buy-mode:hover:not(:disabled) { background: #00e68a; }
        .btn-submit.sell-mode { background: var(--red); color: #fff; }
        .btn-submit.sell-mode:hover:not(:disabled) { background: #ff6672; }

        /* Execution log */
        .exec-log {
            max-width: 440px;
            margin-top: 12px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
        }
        .exec-log-header {
            padding: 6px 12px;
            background: var(--panel2);
            border-bottom: 1px solid var(--border);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .exec-log-body {
            padding: 10px 12px;
            font-family: 'Cascadia Code', 'SF Mono', 'Fira Code', monospace;
            font-size: 10.5px;
            color: #7eb8a4;
            min-height: 80px;
            max-height: 160px;
            overflow-y: auto;
        }
        .exec-log-body::-webkit-scrollbar { width: 3px; }
        .exec-log-body::-webkit-scrollbar-thumb { background: var(--border2); }
        .log-line { margin-bottom: 4px; line-height: 1.4; }
        .log-ts { color: var(--text-dim); margin-right: 6px; }
        .log-success { color: var(--green); }
        .log-info { color: var(--gold); }
        .log-warn { color: var(--working); }

        /* spinner */
        .spin {
            display: inline-block;
            width: 10px;
            height: 10px;
            border: 2px solid rgba(255,255,255,0.2);
            border-top-color: currentColor;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            vertical-align: middle;
            margin-right: 4px;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* ── RIGHT: ORDERS ── */
        .orders-panel {
            width: 260px;
            flex-shrink: 0;
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .orders-content {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
        }
        .orders-content::-webkit-scrollbar { width: 3px; }
        .orders-content::-webkit-scrollbar-thumb { background: var(--border2); }

        .working-order {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 3px;
            padding: 8px 10px;
            margin-bottom: 6px;
        }
        .wo-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }
        .wo-pair {
            font-size: 12px;
            font-weight: 700;
            color: white;
        }
        .wo-status {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.8px;
            padding: 1px 6px;
            border-radius: 2px;
        }
        .wo-status.working { color: var(--working); background: rgba(245,166,35,0.15); }
        .wo-status.filled { color: var(--green); background: var(--green-dim); }
        .wo-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px;
        }
        .wo-item {}
        .wo-label { font-size: 9px; color: var(--text-muted); letter-spacing: 0.3px; }
        .wo-value { font-size: 10.5px; font-weight: 600; color: var(--text); }
        .wo-value.buy { color: var(--green); }
        .wo-value.sell { color: var(--red); }

        /* ── BOTTOM: BLOTTER ── */
        .bottom-layout {
            height: 220px;
            flex-shrink: 0;
            border-top: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .blotter-tabs {
            display: flex;
            align-items: stretch;
            background: #0f1520;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            padding: 0 12px;
            gap: 0;
        }
        .blotter-tab {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            padding: 0 14px;
            height: 28px;
            display: flex;
            align-items: center;
            cursor: pointer;
            color: var(--text-muted);
            border-bottom: 2px solid transparent;
            transition: all 0.15s;
        }
        .blotter-tab:hover { color: var(--text); }
        .blotter-tab.active { color: white; border-bottom-color: var(--gold); }

        .blotter-table-wrap {
            flex: 1;
            overflow: auto;
        }
        .blotter-table-wrap::-webkit-scrollbar { width: 4px; height: 4px; }
        .blotter-table-wrap::-webkit-scrollbar-track { background: transparent; }
        .blotter-table-wrap::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

        .blotter-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10.5px;
            white-space: nowrap;
        }
        .blotter-table thead th {
            background: var(--panel2);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 9.5px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding: 5px 10px;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1;
        }
        .blotter-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.03);
            transition: background 0.1s;
        }
        .blotter-table tbody tr:hover { background: rgba(255,255,255,0.03); }
        .blotter-table tbody td {
            padding: 5px 10px;
            color: var(--text-muted);
            font-size: 10.5px;
        }
        .blotter-table td.highlight { color: var(--text); }
        .status-badge {
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.5px;
            padding: 1px 7px;
            border-radius: 2px;
            display: inline-block;
        }
        .status-badge.filled { background: var(--green-dim); color: var(--green); border: 1px solid rgba(0,201,122,0.3); }
        .status-badge.working { background: rgba(245,166,35,0.12); color: var(--working); border: 1px solid rgba(245,166,35,0.3); }
        .side-buy { color: var(--green); font-weight: 700; }
        .side-sell { color: var(--red); font-weight: 700; }

        /* workflow phase indicator */
        .phase-bar {
            background: var(--panel2);
            border-bottom: 1px solid var(--border);
            padding: 6px 16px;
            display: flex;
            align-items: center;
            gap: 0;
            flex-shrink: 0;
        }
        .phase-step {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding: 3px 12px;
            border-radius: 3px;
            color: var(--text-dim);
            transition: all 0.2s;
        }
        .phase-step .dot {
            width: 5px; height: 5px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }
        .phase-step.done { color: var(--text-muted); }
        .phase-step.done .dot { background: var(--green); }
        .phase-step.active { color: var(--gold); background: var(--gold-dim); }
        .phase-step-sep { color: var(--border2); font-size: 10px; padding: 0 2px; }
    </style>
</head>
<body>
    <!-- TOP NAV -->
    <div class="top-nav">
        <div class="nav-brand">
            <span class="nav-brand-mq">Aurora</span>
            <span class="nav-brand-sep">|</span>
            <span class="nav-brand-aurora">aurora</span>
        </div>
        <ul class="nav-tabs-list">
            <li class="nav-tab">Home</li>
            <li class="nav-tab active">FX</li>
            <li class="nav-tab">FX Options</li>
            <li class="nav-tab">Commodities</li>
            <li class="nav-tab">Insights</li>
            <li class="nav-tab">Post Trade</li>
        </ul>
        <div class="nav-right">
            <span class="account-label">Account</span>
