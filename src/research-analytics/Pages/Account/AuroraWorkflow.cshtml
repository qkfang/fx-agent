        <div class="phase-step active" data-phase="1"><span class="dot"></span>Fetch CRM</div>
        <span class="phase-step-sep">›</span>
        <div class="phase-step" data-phase="2"><span class="dot"></span>Trade Action</div>
        <span class="phase-step-sep">›</span>
        <div class="phase-step" data-phase="3"><span class="dot"></span>Approval</div>
        <span class="phase-step-sep">›</span>
        <div class="phase-step" data-phase="4"><span class="dot"></span>Execute</div>
        <span class="phase-step-sep">›</span>
        <div class="phase-step" data-phase="5"><span class="dot"></span>Review</div>
        <span class="phase-step-sep">›</span>
        <div class="phase-step" data-phase="6"><span class="dot"></span>Update CRM</div>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-layout">

        <!-- LEFT: PRICES -->
        <div class="prices-panel">
            <div class="section-header">
                <span class="section-title">Prices</span>
                <div class="section-actions">
                    <span class="section-title" style="color:#3d5070">Foreign Exchange</span>
                </div>
            </div>
            <div class="tile-grid" id="tileGrid">
                <!-- Primary tile injected by JS -->
            </div>
        </div>

        <!-- CENTER: ORDER TICKET -->
        <div class="order-panel">
            <div class="section-header">
                <span class="section-title" id="orderSectionTitle">Order Ticket</span>
                <div class="section-actions">
                    <button class="section-btn active">Spot</button>
                    <button class="section-btn">Forward</button>
                    <button class="section-btn">Swap</button>
                </div>
            </div>
            <div class="order-content">

                <!-- STEP 1: Fetch CRM -->
                <div id="step1Panel">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair">
                                <i class="fa-solid fa-database" style="color:var(--gold);font-size:13px;"></i>
                                CRM Customer Record
                            </div>
                            <span class="ticket-status pending">PENDING</span>
                        </div>
                        <div class="ticket-body">
                            <div id="step1Content" style="color:var(--text-muted); font-size:11px; padding:8px 0;">
                                Click below to retrieve the customer record from CRM.
                            </div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-submit" onclick="loadCustomerRecords()">
                                <i class="fa-solid fa-database"></i> Fetch Customer Data
                            </button>
                        </div>
                    </div>
                </div>

                <!-- STEP 2: Order Ticket (Trade Action) -->
                <div id="step2Panel" style="display:none;">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair" id="ticketPairLabel">EUR/USD</div>
                            <span class="ticket-status pending">ORDER TICKET</span>
                        </div>
                        <div class="ticket-body">
                            <div class="field-row">
                                <span class="field-label">Order Type</span>
                                <select class="ticket-select">
                                    <option>MARKET</option>
                                    <option>LIMIT</option>
                                    <option>STOP</option>
                                </select>
                            </div>
                            <div class="field-row">
                                <span class="field-label">Direction</span>
                                <div class="toggle-group">
                                    <button class="toggle-btn buy" id="btnBuy" onclick="selectDirection('Buy')">BUY</button>
                                    <button class="toggle-btn sell" id="btnSell" onclick="selectDirection('Sell')">SELL</button>
                                </div>
                            </div>
                            <div class="field-row">
                                <span class="field-label">Customer</span>
                                <span class="field-value" id="ticketCustomer">—</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">AI Signal</span>
                                <span class="field-value" id="ticketSignal" style="color:var(--gold);">—</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">Qty (Lots)</span>
                                <input type="number" class="ticket-input-large" id="lotsInput" value="0.10" min="0.01" max="100" step="0.01" />
                            </div>
                            <div style="display:flex;gap:4px;margin-bottom:12px;margin-left:128px;">
                                <button class="section-btn" onclick="setLots(0.01)">0.01</button>
                                <button class="section-btn" onclick="setLots(0.10)">0.10</button>
                                <button class="section-btn" onclick="setLots(0.50)">0.50</button>
                                <button class="section-btn" onclick="setLots(1.00)">1.00</button>
                                <button class="section-btn" onclick="setLots(5.00)">5.00</button>
                            </div>
                            <div class="ticket-divider"></div>
                            <div class="field-row">
                                <span class="field-label">Mkt Price</span>
                                <div class="mkt-price-row">
                                    <span class="mkt-price-val" id="mktPriceDisplay">—</span>
                                    <span class="mkt-price-pip pos" id="pipDisplay">live</span>
                                </div>
                            </div>
                            <div class="field-row">
                                <span class="field-label">Pdt Type</span>
                                <span class="field-value">SPOT</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">Time In Force</span>
                                <select class="ticket-select">
                                    <option>GTC</option>
                                    <option>Day</option>
                                    <option>IOC</option>
                                    <option>FOK</option>
                                </select>
                            </div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-reset" onclick="goPhase(1)">RESET</button>
                            <button class="btn-ticket btn-clone" id="btnReview" onclick="goPhase(3)">REVIEW</button>
                            <button class="btn-ticket btn-submit" id="btnSubmit2" onclick="goPhase(3)" disabled>SUBMIT</button>
                        </div>
                    </div>
                </div>

                <!-- STEP 3: Approval -->
                <div id="step3Panel" style="display:none;">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair">
                                <i class="fa-solid fa-shield-check" style="color:var(--gold);font-size:13px;"></i>
                                Trade Approval
                            </div>
                            <span class="ticket-status pending">REVIEW</span>
                        </div>
                        <div class="ticket-body">
                            <div class="field-group-label">Trade Summary</div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Customer</div>
                                    <div class="wo-value" id="approvalCustomer" style="font-size:11px;">—</div>
                                </div>
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Direction</div>
                                    <div class="wo-value" id="approvalAction" style="font-size:13px;font-weight:800;">—</div>
                                </div>
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Pair</div>
                                    <div class="wo-value" id="approvalPair" style="font-size:12px;font-weight:700;">—</div>
                                </div>
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Rate</div>
                                    <div class="wo-value" id="approvalRate" style="font-size:13px;font-family:monospace;">—</div>
                                </div>
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Volume</div>
                                    <div class="wo-value" id="approvalLots" style="font-size:12px;">—</div>
                                </div>
                                <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                                    <div class="wo-label">Est. Notional</div>
                                    <div class="wo-value" id="approvalNotional" style="font-size:11px;">—</div>
                                </div>
                            </div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-reset" onclick="goPhase(2)">BACK</button>
                            <button class="btn-ticket btn-submit" id="btnApprove" onclick="goPhase(4)">
                                <i class="fa-solid fa-check"></i> APPROVE &amp; EXECUTE
                            </button>
                        </div>
                    </div>
                </div>

                <!-- STEP 4: Execute -->
                <div id="step4Panel" style="display:none;">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair">
                                <i class="fa-solid fa-bolt" style="color:var(--gold);font-size:13px;"></i>
                                Executing Trade
                            </div>
                            <span class="ticket-status executing" id="execStatus">EXECUTING</span>
                        </div>
                        <div class="ticket-body" style="padding:8px 14px;">
                            <div class="exec-log-body" id="agentLogs" style="min-height:120px;max-height:200px;padding:0;background:none;border:none;">
                                <div class="log-line log-info"><span class="log-ts">[INIT]</span>Initializing Aurora trading agent...</div>
                            </div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-submit" id="btnStep4Next" onclick="goPhase(5)" disabled>
                                <span class="spin"></span>Executing...
                            </button>
                        </div>
                    </div>
                </div>

                <!-- STEP 5: Review Result -->
                <div id="step5Panel" style="display:none;">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair">
                                <i class="fa-solid fa-circle-check" style="color:var(--green);font-size:13px;"></i>
                                Trade Result
                            </div>
                            <span class="ticket-status filled" id="resultStatus">FILLED</span>
                        </div>
                        <div class="ticket-body">
                            <div id="resultDetails" style="font-size:11px;line-height:1.8;color:var(--text-muted);"></div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-reset" onclick="rejectTrade()">
                                <i class="fa-solid fa-xmark"></i> REJECT
                            </button>
                            <button class="btn-ticket btn-submit" onclick="goPhase(6)">
                                <i class="fa-solid fa-check"></i> ACCEPT &amp; UPDATE CRM
                            </button>
                        </div>
                    </div>
                </div>

                <!-- STEP 6: Update CRM -->
                <div id="step6Panel" style="display:none;">
                    <div class="order-ticket">
                        <div class="ticket-header">
                            <div class="ticket-pair">
                                <i class="fa-solid fa-rotate" style="color:var(--gold);font-size:13px;"></i>
                                Update CRM
                            </div>
                            <span class="ticket-status executing" id="crmStatus">UPDATING</span>
                        </div>
                        <div class="ticket-body" style="padding:8px 14px;">
                            <div class="exec-log-body" id="crmLogs" style="min-height:120px;max-height:200px;padding:0;background:none;border:none;">
                                <div class="log-line log-info"><span class="log-ts">[INIT]</span>Preparing CRM update...</div>
                            </div>
                        </div>
                        <div class="ticket-footer">
                            <button class="btn-ticket btn-submit" id="btnComplete" onclick="completeWorkflow()" disabled>
                                <span class="spin"></span>Updating CRM...
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- RIGHT: ORDERS -->
        <div class="orders-panel">
            <div class="section-header">
                <span class="section-title">Orders</span>
                <div class="section-actions">
                    <button class="section-btn active">Calendar</button>
                    <button class="section-btn">News</button>
                </div>
            </div>
            <div class="orders-content" id="ordersContent">
                <div style="color:var(--text-dim);font-size:10px;text-align:center;padding:20px 0;">No working orders</div>
            </div>
        </div>

    </div>

    <!-- BOTTOM: BLOTTER -->
    <div class="bottom-layout">
        <div class="blotter-tabs">
            <div class="blotter-tab active">Blotter</div>
            <div class="blotter-tab">Positions</div>
            <div class="blotter-tab">Trade History</div>
        </div>
        <div class="blotter-table-wrap">
            <table class="blotter-table">
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Last Updated</th>
                        <th>Status</th>
                        <th>Order Type</th>
                        <th>Product Type</th>
                        <th>Security</th>
                        <th>Side</th>
                        <th>Currency</th>
                        <th>Qty</th>
                        <th>Cum Qty</th>
                        <th>Avg Px</th>
                        <th>TIF</th>
                        <th>Contra</th>
                    </tr>
                </thead>
                <tbody id="blotterBody">
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        const AURORA_API = '@Model.AuroraApiUrl';
        const AURORA_QUOTE = '@Model.AuroraQuoteUrl';
        const FOUNDRY_AGENT = '@Model.FoundryAgentUrl';

        let quoteInterval = null;
        let currentPhase = 1;
        let tradeData = {
            customer: '@Model.CustomerName',
            pair: '@Model.CurrencyPair',
            signal: '@Model.Signal',
            action: null,
            lots: 0.10,
            rate: 0,
            bid: 0,
            ask: 0,
            transactionId: null
        };

        // ── Init ─────────────────────────────────────────────
        window.addEventListener('DOMContentLoaded', function () {
            renderTile(null, null);
            startQuoteFeed();
            renderBlotter([]);
            goPhase(1);
        });

        // ── Phase navigation ──────────────────────────────────
        function goPhase(n) {
            currentPhase = n;
            ['step1Panel','step2Panel','step3Panel','step4Panel','step5Panel','step6Panel']
                .forEach(id => document.getElementById(id).style.display = 'none');
            document.getElementById('step' + n + 'Panel').style.display = 'block';

            document.querySelectorAll('.phase-step').forEach(el => {
                const p = parseInt(el.dataset.phase);
                el.classList.remove('active', 'done');
                if (p < n) el.classList.add('done');
                if (p === n) el.classList.add('active');
            });

            if (n === 2) populateStep2();
            if (n === 3) populateApproval();
            if (n === 4) executeAgent();
            if (n === 5) showResult();
            if (n === 6) updateCRM();
        }

        // ── FX Tile ───────────────────────────────────────────
        function renderTile(bid, ask) {
            const pair = tradeData.pair.replace('/', '');
            const ccy1 = tradeData.pair.split('/')[0] || 'AUD';
            const ccy2 = tradeData.pair.split('/')[1] || 'USD';
            const spread = (bid && ask) ? ((ask - bid) * 10000).toFixed(1) : '—';

            const bidStr = bid ? bid.toFixed(5) : '——.——';
            const askStr = ask ? ask.toFixed(5) : '——.——';

            // Split price into main 2 digits + pips
            function splitPrice(p) {
                if (!p) return { main: '——', pips: '——' };
                const s = p.toFixed(5);
                const parts = s.split('.');
                const dec = parts[1] || '00000';
                return { main: parts[0] + '.' + dec.slice(0, 2), pips: dec.slice(2, 4) + '<sup style="font-size:8px">' + dec.slice(4) + '</sup>' };
            }
            const b = splitPrice(bid);
            const a = splitPrice(ask);

            document.getElementById('tileGrid').innerHTML = `
                <div class="fx-tile active">
                    <div class="tile-header">
                        <div class="tile-pair">
                            <span style="font-size:16px;">🇦🇺</span>
                            ${tradeData.pair}
                            <span class="tile-type">SPOT</span>
                        </div>
                        <div class="tile-actions">
                            <button class="tile-btn">RFQ</button>
                        </div>
                    </div>
                    <div class="tile-prices">
                        <div class="tile-sell" onclick="if(currentPhase===2)selectDirection('Sell')">
                            <div class="tile-sell-label">Sell ${ccy1}</div>
                            <div class="sell-price">
                                <span class="price-main">${b.main}</span>
                                <span class="price-pips">${b.pips}</span>
                            </div>
                        </div>
                        <div class="tile-mid">
                            <div class="tile-center" style="font-size:9px;margin-bottom:4px;">spread</div>
                            <div class="tile-mid-rate">${spread}</div>
                        </div>
                        <div class="tile-buy" onclick="if(currentPhase===2)selectDirection('Buy')">
                            <div class="tile-buy-label">Buy ${ccy1}</div>
                            <div class="buy-price">
                                <span class="price-main">${a.main}</span>
                                <span class="price-pips">${a.pips}</span>
                            </div>
                        </div>
                    </div>
                    <div class="tile-tenors">
                        <button class="tenor-btn active">1M</button>
                        <button class="tenor-btn">2M</button>
                        <button class="tenor-btn">5M</button>
                        <button class="tenor-btn">10M</button>
                    </div>
                    <div class="tile-footer">
                        <div class="tile-qty"><strong>1,000,000.00</strong> ${ccy1} SP / ${new Date().toISOString().slice(0,10)}</div>
                        <button class="tile-order-btn" onclick="goPhase(2)">ORDER</button>
                    </div>
                </div>
            `;
        }

        // ── Quote feed ─────────────────────────────────────────
        async function startQuoteFeed() {
            await fetchQuote();
            quoteInterval = setInterval(fetchQuote, 3000);
        }

        async function fetchQuote() {
            try {
                const res = await fetch(AURORA_QUOTE);
                if (!res.ok) throw new Error();
                const q = await res.json();
                tradeData.bid = q.bid;
                tradeData.ask = q.ask;
                renderTile(q.bid, q.ask);
                if (currentPhase === 2) {
                    const rate = tradeData.action === 'Sell' ? q.bid : q.ask;
                    document.getElementById('mktPriceDisplay').textContent = rate.toFixed(4);
                    tradeData.rate = rate;
                }
            } catch {
                // keep last values
            }
        }

        // ── Step 1 ─────────────────────────────────────────────
        async function loadCustomerRecords() {
            const content = document.getElementById('step1Content');
            content.innerHTML = '<span class="spin" style="color:var(--gold);"></span> Fetching customer data from CRM...';
            await sleep(1500);

            content.innerHTML = `
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:4px;">
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:7px 10px;">
                        <div class="wo-label">Customer</div>
                        <div class="wo-value" style="font-size:11px;">${tradeData.customer}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:7px 10px;">
                        <div class="wo-label">Pair</div>
                        <div class="wo-value" style="font-size:12px;font-weight:700;">${tradeData.pair}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:7px 10px;">
                        <div class="wo-label">AI Signal</div>
                        <div class="wo-value" style="color:var(--gold);">${tradeData.signal}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:7px 10px;">
                        <div class="wo-label">Status</div>
                        <div class="wo-value" style="color:var(--green);">Verified</div>
                    </div>
                </div>
                <div style="margin-top:10px;font-size:10px;color:var(--green);"><i class="fa-solid fa-circle-check"></i> Record retrieved successfully</div>

                <div style="margin-top:14px;">
                    <div style="font-size:9.5px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px;">
                        Position Summary – Bank Deals
                    </div>
                    <div style="overflow-x:auto;">
                        <table style="width:100%;border-collapse:collapse;font-size:10px;white-space:nowrap;">
                            <thead>
                                <tr>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:left;">CCY</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">25-Jul-2025</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">28-Jul-2025</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">29-Jul-2025</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">30-Jul-2025</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">31-Jul-2025</th>
                                    <th style="background:var(--panel2);color:var(--text-muted);font-weight:600;font-size:9px;letter-spacing:0.5px;text-transform:uppercase;padding:5px 8px;border-bottom:1px solid var(--border);text-align:right;">&gt; 31-Jul-2025</th>
                                </tr>
                            </thead>
                            <tbody id="positionBody"></tbody>
                        </table>
                    </div>
                    <div style="margin-top:5px;font-size:9px;color:var(--text-dim);display:flex;justify-content:space-between;">
                        <span>Number of rows <strong style="color:var(--text-muted)" id="posRowCount">0</strong></span>
                        <span id="posLastUpdated" style="color:var(--text-dim);"></span>
                    </div>
                </div>
            `;

            // Render position grid
            const positions = [
                { ccy: 'AUD', flag: '🇦🇺', d1: 8996330.00,      d2: -1693459.50,     d3: -958926.00,       d4: -2197670.00,    d5: 1501000.00,    dn: -9853963.00  },
                { ccy: 'BRL', flag: '🇧🇷', d1: -561381800.00,   d2: -77751800.00,    d3: null,             d4: 4568200.00,     d5: null,          dn: -9410791800.00 },
                { ccy: 'CAD', flag: '🇨🇦', d1: 13616.60,        d2: 91795.50,        d3: null,             d4: null,           d5: null,          dn: -91642.10    },
                { ccy: 'EUR', flag: '🇪🇺', d1: null,            d2: 462368.20,       d3: -30000000.00,     d4: 30000000.00,    d5: 297000.00,     dn: -523806762.50},
                { ccy: 'GBP', flag: '🇬🇧', d1: 118000.00,       d2: 59000.00,        d3: null,             d4: -141000.00,     d5: -65000.00,     dn: 35254.80     },
                { ccy: 'INR', flag: '🇮🇳', d1: -4467944540.00,  d2: 7402846811.10,   d3: -1467580000.00,   d4: 100587000.00,   d5: -6529000.00,   dn: -55601656016.16 },
                { ccy: 'JPY', flag: '🇯🇵', d1: null,            d2: -2436340,        d3: null,             d4: 26271946,       d5: null,          dn: 4533468233   },
                { ccy: 'KRW', flag: '🇰🇷', d1: 389661000,       d2: 649435000,       d3: 224690000,        d4: 484464000,      d5: null,          dn: null         },
                { ccy: 'USD', flag: '🇺🇸', d1: 163926116.36,    d2: -88005700.47,    d3: 53629887.86,      d4: -36484971.97,   d5: -1266006.23,   dn: 3516657892.85 }
            ];

            function fmtPos(v) {
                if (v === null || v === undefined) return '<span style="color:var(--text-dim)">-</span>';
                const neg = v < 0;
                const abs = Math.abs(v).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                return '<span style="color:' + (neg ? 'var(--red)' : 'var(--text)') + '">' + (neg ? '-' : '') + abs + '</span>';
            }

            const tbody = document.getElementById('positionBody');
            tbody.innerHTML = positions.map(p => `
                <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
                    <td style="padding:5px 8px;color:var(--text);font-weight:600;">${p.flag} ${p.ccy}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.d1)}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.d2)}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.d3)}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.d4)}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.d5)}</td>
                    <td style="padding:5px 8px;text-align:right;">${fmtPos(p.dn)}</td>
                </tr>
            `).join('');
            document.getElementById('posRowCount').textContent = positions.length;
            document.getElementById('posLastUpdated').textContent = 'Last updated: just now';

            const footer = document.querySelector('#step1Panel .ticket-footer');
            footer.innerHTML = `
                <button class="btn-ticket btn-reset" onclick="goPhase(1); location.reload();">RESET</button>
                <button class="btn-ticket btn-submit" onclick="goPhase(2)">CONTINUE <i class="fa-solid fa-arrow-right"></i></button>
            `;
        }

        // ── Step 2 ─────────────────────────────────────────────
        function populateStep2() {
            document.getElementById('ticketPairLabel').textContent = tradeData.pair;
            document.getElementById('ticketCustomer').textContent = tradeData.customer;
            document.getElementById('ticketSignal').textContent = tradeData.signal;
            const rate = tradeData.action === 'Sell' ? tradeData.bid : tradeData.ask;
            document.getElementById('mktPriceDisplay').textContent = rate ? rate.toFixed(4) : '—';
            if (tradeData.action) highlightDirection(tradeData.action);
        }

        function selectDirection(dir) {
            tradeData.action = dir;
            highlightDirection(dir);
            document.getElementById('btnSubmit2').disabled = false;
            const rate = dir === 'Buy' ? tradeData.ask : tradeData.bid;
            tradeData.rate = rate;
            document.getElementById('mktPriceDisplay').textContent = rate ? rate.toFixed(4) : '—';
            const btn = document.getElementById('btnSubmit2');
            btn.className = 'btn-ticket btn-submit ' + (dir === 'Buy' ? 'buy-mode' : 'sell-mode');
            btn.textContent = dir.toUpperCase();
        }

        function highlightDirection(dir) {
            document.getElementById('btnBuy').classList.toggle('active', dir === 'Buy');
            document.getElementById('btnSell').classList.toggle('active', dir === 'Sell');
        }

        function setLots(v) {
            document.getElementById('lotsInput').value = v.toFixed(2);
        }

        // ── Step 3 ─────────────────────────────────────────────
        function populateApproval() {
            tradeData.lots = parseFloat(document.getElementById('lotsInput').value) || 0.10;
            const rate = tradeData.action === 'Buy' ? tradeData.ask : tradeData.bid;
            tradeData.rate = rate || tradeData.rate;
            const notional = Math.round(tradeData.lots * 100000 * tradeData.rate);

            document.getElementById('approvalCustomer').textContent = tradeData.customer;
            const aEl = document.getElementById('approvalAction');
            aEl.textContent = tradeData.action || '—';
            aEl.className = 'wo-value ' + (tradeData.action === 'Buy' ? 'buy' : 'sell');
            document.getElementById('approvalPair').textContent = tradeData.pair;
            document.getElementById('approvalRate').textContent = tradeData.rate ? tradeData.rate.toFixed(5) : '—';
            document.getElementById('approvalLots').textContent = tradeData.lots.toFixed(2) + ' lots';
            document.getElementById('approvalNotional').textContent = notional ? '$' + notional.toLocaleString() : '—';
        }

        // ── Step 4 ─────────────────────────────────────────────
        async function executeAgent() {
            const logs = document.getElementById('agentLogs');
            const btn = document.getElementById('btnStep4Next');
            logs.innerHTML = '';

            await sleep(600);
            addLog(logs, 'info', 'Connecting to Aurora trading agent...');
            await sleep(900);
            addLog(logs, 'success', 'Connection established');
            await sleep(500);
            addLog(logs, 'info', `Submitting ${tradeData.action} ${tradeData.lots} lots ${tradeData.pair}...`);
            await sleep(1100);
            addLog(logs, 'info', 'Order routed to liquidity provider...');
            await sleep(1300);

            try {
                const res = await fetch(AURORA_API + '/trade', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        direction: tradeData.action,
                        currencyPair: tradeData.pair,
                        lots: tradeData.lots,
                        accountId: 1,
                        customerName: tradeData.customer
                    })
                });
                const data = await res.json();
                if (data.success) {
                    tradeData.transactionId = data.transactionId;
                    tradeData.rate = data.rate || tradeData.rate;
                    addLog(logs, 'success', `✓ Filled at ${tradeData.rate.toFixed(5)}`);
                    addLog(logs, 'success', `Transaction: ${data.transactionId}`);
                } else {
                    addLog(logs, 'warn', `✗ ${data.message}`);
                }
            } catch {
                tradeData.transactionId = 'AU-' + Date.now();
                addLog(logs, 'success', `✓ Filled at ${tradeData.rate.toFixed(5)}`);
                addLog(logs, 'success', `Transaction: ${tradeData.transactionId}`);
            }

            // Call fxag-trader agent to process the trade response
            await sleep(500);
            addLog(logs, 'info', 'Sending trade details to trading agent...');
            try {
                const agentMsg = `Trade executed: ${tradeData.action} ${tradeData.lots} lots ${tradeData.pair} at ${tradeData.rate.toFixed(5)}, transaction ${tradeData.transactionId}. Please retrieve the latest transaction history and fund summary to confirm.`;
                const agentRes = await fetch(FOUNDRY_AGENT + '/trader', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: agentMsg })
                });
                if (!agentRes.ok) throw new Error(`Agent returned ${agentRes.status}`);
                const agentData = await agentRes.json();
                addLog(logs, 'success', '✓ Trading agent confirmed transaction');
                if (agentData.response && typeof agentData.response === 'string') {
                    tradeData.agentResponse = agentData.response;
                    addLog(logs, 'info', 'Agent: ' + agentData.response.substring(0, 200));
                }
            } catch (agentErr) {
                addLog(logs, 'warn', 'Trading agent unavailable — trade still recorded');
            }

            addLog(logs, 'success', 'Execution complete');
            document.getElementById('execStatus').textContent = 'FILLED';
            document.getElementById('execStatus').className = 'ticket-status filled';
            btn.innerHTML = 'View Result <i class="fa-solid fa-arrow-right"></i>';
            btn.disabled = false;
            addWorkingOrder();
        }

        // ── Step 5 ─────────────────────────────────────────────
        function showResult() {
            const notional = Math.round(tradeData.lots * 100000 * tradeData.rate);
            document.getElementById('resultDetails').innerHTML = `
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                        <div class="wo-label">Security</div>
                        <div class="wo-value" style="font-size:12px;font-weight:700;">${tradeData.pair}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                        <div class="wo-label">Side</div>
                        <div class="wo-value ${tradeData.action === 'Buy' ? 'buy' : 'sell'}" style="font-size:13px;font-weight:800;">${tradeData.action?.toUpperCase()}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                        <div class="wo-label">Avg Px</div>
                        <div class="wo-value" style="font-size:13px;font-family:monospace;">${tradeData.rate.toFixed(5)}</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;">
                        <div class="wo-label">Qty</div>
                        <div class="wo-value">${tradeData.lots} lots</div>
                    </div>
                    <div style="background:var(--panel2);border:1px solid var(--border);border-radius:3px;padding:8px 10px;grid-column:span 2;">
                        <div class="wo-label">Transaction ID</div>
                        <div class="wo-value" style="font-family:monospace;font-size:11px;">${tradeData.transactionId}</div>
                    </div>
                </div>
                <div style="margin-top:10px;font-size:10px;color:var(--green);"><i class="fa-solid fa-circle-check"></i> Trade executed — notional $${notional.toLocaleString()}</div>
            `;
            addBlotterRow();
        }

        // ── Step 6 ─────────────────────────────────────────────
        async function updateCRM() {
            const logs = document.getElementById('crmLogs');
            const btn = document.getElementById('btnComplete');
            logs.innerHTML = '';

            await sleep(800); addLog(logs, 'info', 'Connecting to CRM...');
            await sleep(1000); addLog(logs, 'success', 'Connection established');
            await sleep(700); addLog(logs, 'info', `Updating customer record: ${tradeData.customer}`);
            await sleep(900); addLog(logs, 'info', 'Adding transaction to portfolio history...');
            await sleep(800); addLog(logs, 'info', 'Updating account balance and positions...');
            await sleep(900); addLog(logs, 'success', '✓ Portfolio updated');
            await sleep(600); addLog(logs, 'info', 'Generating trade confirmation...');
            await sleep(700); addLog(logs, 'success', '✓ Confirmation sent');
            await sleep(500); addLog(logs, 'success', '✓ CRM update complete');

            document.getElementById('crmStatus').textContent = 'DONE';
            document.getElementById('crmStatus').className = 'ticket-status filled';
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Complete Workflow';
            btn.disabled = false;
        }

        function completeWorkflow() {
            window.location.href = '/Account';
        }

        function rejectTrade() {
            if (confirm('Reject this trade? This will cancel the order.')) {
                window.location.href = '/Account';
            }
        }

        // ── Working orders panel ──────────────────────────────
        function addWorkingOrder() {
            document.getElementById('ordersContent').innerHTML = `
                <div class="working-order">
                    <div class="wo-header">
                        <div class="wo-pair">${tradeData.pair}</div>
                        <span class="wo-status filled">FILLED</span>
                    </div>
                    <div class="wo-details">
                        <div class="wo-item">
                            <div class="wo-label">Side</div>
                            <div class="wo-value ${tradeData.action === 'Buy' ? 'buy' : 'sell'}">${tradeData.action?.toUpperCase()}</div>
                        </div>
                        <div class="wo-item">
                            <div class="wo-label">Qty</div>
                            <div class="wo-value">${(tradeData.lots * 1000000).toLocaleString()}</div>
                        </div>
                        <div class="wo-item">
                            <div class="wo-label">Avg Px</div>
                            <div class="wo-value">${tradeData.rate.toFixed(5)}</div>
                        </div>
                        <div class="wo-item">
                            <div class="wo-label">Type</div>
                            <div class="wo-value">SPOT</div>
                        </div>
                    </div>
                </div>
            `;
        }

        // ── Blotter ───────────────────────────────────────────
        let blotterRows = [];
        function renderBlotter(rows) {
            const body = document.getElementById('blotterBody');
            if (!rows.length) {
                body.innerHTML = '<tr><td colspan="13" style="text-align:center;color:var(--text-dim);padding:16px;">No trades</td></tr>';
                return;
            }
            body.innerHTML = rows.map(r => `
                <tr>
                    <td class="highlight">${r.created}</td>
                    <td>${r.updated}</td>
                    <td><span class="status-badge ${r.status.toLowerCase()}">${r.status}</span></td>
                    <td>${r.orderType}</td>
                    <td>${r.productType}</td>
                    <td class="highlight">${r.security}</td>
                    <td class="${r.side === 'BUY' ? 'side-buy' : 'side-sell'}">${r.side}</td>
                    <td>${r.currency}</td>
                    <td class="highlight">${r.qty}</td>
                    <td>${r.cumQty}</td>
                    <td class="highlight">${r.avgPx}</td>
                    <td>${r.tif}</td>
                    <td>${r.contra}</td>
                </tr>
            `).join('');
        }

        function addBlotterRow() {
            const now = new Date();
            const ts = now.toLocaleDateString() + ' ' + now.toLocaleTimeString();
            const [ccy1, ccy2] = tradeData.pair.split('/');
            blotterRows.unshift({
                created: ts,
                updated: ts,
                status: 'FILLED',
                orderType: 'SPOT',
                productType: 'SPOT',
                security: tradeData.pair,
                side: tradeData.action?.toUpperCase(),
                currency: ccy1,
                qty: (tradeData.lots * 1000000).toLocaleString(),
                cumQty: (tradeData.lots * 1000000).toLocaleString(),
                avgPx: tradeData.rate.toFixed(5),
                tif: 'GTC',
                contra: ccy2 + ': ' + (tradeData.lots * 100000 * tradeData.rate).toLocaleString(undefined, {maximumFractionDigits:0})
            });
            renderBlotter(blotterRows);
        }

        // ── Helpers ───────────────────────────────────────────
        function addLog(container, type, message) {
            const ts = new Date().toLocaleTimeString();
            const div = document.createElement('div');
            div.className = 'log-line log-' + type;
            div.innerHTML = `<span class="log-ts">[${ts}]</span>${message}`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
    </script>
</body>
</html>
