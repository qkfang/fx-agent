@page
@model FxWebPortal.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.TotalArticles</div>
            <div class="stat-label">Total Articles</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.PublishedCount</div>
            <div class="stat-label">Published</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.TotalVisits</div>
            <div class="stat-label">Total Visits</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-value">@Model.TotalLeads</div>
            <div class="stat-label">Leads Captured</div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs admin-tabs mb-4" id="adminTabs">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-articles">📄 Research Notes</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-drafts">📝 Drafts</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-visitors">👁 Visitor Analytics</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-leads">🎯 Leads</button></li>
</ul>

<div class="tab-content">

    <!-- ── Tab 1: Articles ── -->
    <div class="tab-pane fade show active" id="tab-articles">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Research Notes</h5>
            <a href="/Admin/Edit" class="btn btn-primary btn-sm">+ New Research Note</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Sentiment</th>
                        <th>Author</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Articles)
                    {
                        <tr>
                            <td>@a.Id</td>
                            <td><a href="/Article?id=@a.Id" target="_blank" class="text-decoration-none">@a.Title</a></td>
                            <td><span class="cat-badge cat-@(a.Category.Replace("/","-").Replace(" ","-").ToLower())">@a.Category</span></td>
                            <td><span class="sentiment-badge sentiment-@a.Sentiment.ToLower()">@a.Sentiment</span></td>
                            <td>@a.Author</td>
                            <td>@a.PublishedDate.ToString("yyyy-MM-dd")</td>
                            <td class="d-flex gap-1 flex-wrap">
                                <a href="/Admin/Edit?id=@a.Id" class="btn btn-xs btn-outline-primary">Edit</a>
                                @if (a.Status == "Draft")
                                {
                                    <form method="post" asp-page-handler="Publish" asp-route-id="@a.Id" style="display:inline">
                                        <button class="btn btn-xs btn-success" type="submit">Publish</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Unpublish" asp-route-id="@a.Id" style="display:inline">
                                        <button class="btn btn-xs btn-warning" type="submit">Unpublish</button>
                                    </form>
                                }
                                <form method="post" asp-page-handler="Delete" asp-route-id="@a.Id" style="display:inline">
                                    <button class="btn btn-xs btn-danger" type="submit" onclick="return confirm('Delete this article?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Tab 2: Drafts ── -->
    <div class="tab-pane fade" id="tab-drafts">
        <h5 class="mb-3">Research Drafts</h5>

        <!-- Publish progress overlay -->
        <div id="publish-progress" class="mb-3" style="display:none">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-title mb-2" id="publish-title">Processing...</h6>
                    <div class="progress mb-2" style="height:22px">
                        <div id="publish-bar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:0%">0%</div>
                    </div>
                    <div id="publish-steps">
                        <div id="step-load" class="text-muted small">⏳ Loading draft...</div>
                        <div id="step-article" class="text-muted small">⏳ Publishing article & removing draft...</div>
                        <div id="step-agent" class="text-muted small">⏳ Engaging suggestion agent...</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th>Status</th>
                        <th>Version</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Drafts)
                    {
                        <tr id="draft-row-@d.Id">
                            <td>@d.Id</td>
                            <td>@d.Title</td>
                            <td><span class="cat-badge cat-@(d.Category.Replace("/","-").Replace(" ","-").ToLower())">@d.Category</span></td>
                            <td>@d.Author</td>
                            <td><span class="badge bg-secondary">@d.Status</span></td>
                            <td>@d.Version</td>
                            <td>@d.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <button class="btn btn-xs btn-success btn-publish-draft" type="button"
                                        data-draft-id="@d.Id" data-draft-title="@d.Title"
                                        onclick="publishDraft(this)">
                                    Publish
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Drafts.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted">No drafts available.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Tab 3: Visitor Analytics ── -->
    <div class="tab-pane fade" id="tab-visitors">
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-value">@Model.UniqueSessions</div>
                    <div class="stat-label">Unique Sessions</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-value">@Model.AvgTimeSpent.ToString("0")s</div>
                    <div class="stat-label">Avg Time on Page</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-value">@Model.TotalVisits</div>
                    <div class="stat-label">Total Page Views</div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover admin-table">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Page</th>
                        <th>Article</th>
                        <th>Time Spent</th>
                        <th>Clicks</th>
                        <th>Language</th>
                        <th>Timezone</th>
                        <th>Screen</th>
                        <th>IP</th>
                        <th>Visited At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Visitors)
                    {
                        <tr>
                            <td><span class="session-id" title="@v.SessionId">@v.SessionId[..Math.Min(12, v.SessionId.Length)]…</span></td>
                            <td class="text-truncate" style="max-width:160px" title="@v.PageUrl">@v.PageUrl</td>
                            <td>
                                @if (v.ArticleId.HasValue)
                                {
                                    var art = Model.Articles.FirstOrDefault(a => a.Id == v.ArticleId.Value);
                                    if (art != null)
                                    {
                                        var artTitle = art.Title ?? string.Empty;
                                        <a href="/Article?id=@art.Id" target="_blank">@artTitle[..Math.Min(30, artTitle.Length)]…</a>
                                    }
                                    else
                                    {
                                        <span>#@v.ArticleId</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Homepage</span>
                                }
                            </td>
                            <td>@v.TimeSpentSeconds s</td>
                            <td>@v.ClickCount</td>
                            <td>@v.Language</td>
                            <td>@v.Timezone</td>
                            <td>@v.ScreenSize</td>
                            <td>@v.IpAddress</td>
                            <td>@v.VisitedAt.ToString("MM-dd HH:mm")</td>
                        </tr>
                    }
                    @if (!Model.Visitors.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted">No visitor data yet. Share your research to attract readers!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Tab 4: Leads ── -->
    <div class="tab-pane fade" id="tab-leads">
        <h5 class="mb-3">Lead Generation</h5>
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Company</th>
                        <th>Article</th>
                        <th>Time Spent</th>
                        <th>Session</th>
                        <th>IP</th>
                        <th>Captured At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model.Leads)
                    {
                        <tr>
                            <td>@l.UserName</td>
                            <td><a href="mailto:@l.UserEmail">@l.UserEmail</a></td>
                            <td>@l.UserCompany</td>
                            <td>
                                @if (l.ArticleId.HasValue)
                                {
                                    var art = Model.Articles.FirstOrDefault(a => a.Id == l.ArticleId.Value);
                                    if (art != null)
                                    {
                                        var artTitle = art.Title ?? string.Empty;
                                        <a href="/Article?id=@art.Id" target="_blank">@artTitle[..Math.Min(30, artTitle.Length)]…</a>
                                    }
                                }
                            </td>
                            <td>@l.TimeSpentSeconds s</td>
                            <td><span class="session-id" title="@l.SessionId">@l.SessionId[..Math.Min(12, l.SessionId.Length)]…</span></td>
                            <td>@l.IpAddress</td>
                            <td>@l.VisitedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <form method="post" asp-page-handler="SendToBroker" asp-route-id="@l.Id" style="display:inline">
                                    <button class="btn btn-xs btn-outline-primary" type="submit"
                                            title="Send this lead to Broker Backoffice">
                                        <i class="fa-solid fa-paper-plane"></i> Send to Broker
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Leads.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted">No leads captured yet. Leads appear when visitors submit the research subscription form.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
<script>
    function publishDraft(btn) {
        if (!confirm('Publish this draft as a research article?')) return;

        var draftId = btn.getAttribute('data-draft-id');
        var draftTitle = btn.getAttribute('data-draft-title');

        btn.disabled = true;
        document.querySelectorAll('.btn-publish-draft').forEach(function(b) { b.disabled = true; });

        var progress = document.getElementById('publish-progress');
        var bar = document.getElementById('publish-bar');
        var title = document.getElementById('publish-title');
        progress.style.display = 'block';
        title.textContent = 'Publishing: ' + draftTitle;

        setStep('step-load', 'running', 'Loading draft...');
        setBar(bar, 10);

        setTimeout(function () {
            setStep('step-load', 'done', 'Draft loaded');
            setStep('step-article', 'running', 'Publishing article & removing draft...');
            setBar(bar, 30);

            fetch('/api/admin/publish-draft/' + draftId, { method: 'POST' })
                .then(function (res) {
                    if (!res.ok) {
                        return res.json().then(function (d) { throw new Error(d.error || d.detail || 'Publish failed'); });
                    }
                    return res.json();
                })
                .then(function (data) {
                    setStep('step-article', 'done', 'Article created & draft removed');
                    setStep('step-agent', 'running', 'Engaging suggestion agent...');
                    setBar(bar, 60);

                    var row = document.getElementById('draft-row-' + draftId);
                    if (row) row.remove();

                    return fetch('/api/admin/engage-agent/' + data.articleId, { method: 'POST' });
                })
                .then(function (res) {
                    if (!res.ok) {
                        setStep('step-agent', 'warn', 'Agent engagement failed');
                        throw new Error('agent-skip');
                    }
                    return res.json();
                })
                .then(function (data) {
                    if (data.agentNotified) {
                        setStep('step-agent', 'done', 'Suggestion agent engaged');
                    } else {
                        setStep('step-agent', 'warn', 'Agent notification skipped');
                    }
                    setBar(bar, 100);
                    bar.classList.remove('progress-bar-animated');
                    bar.classList.add('bg-success');
                })
                .catch(function (err) {
                    if (err.message === 'agent-skip') {
                        setBar(bar, 100);
                        bar.classList.remove('progress-bar-animated');
                        bar.classList.add('bg-warning');
                        return;
                    }
                    setBar(bar, 100);
                    bar.classList.remove('progress-bar-animated');
                    bar.classList.add('bg-danger');
                    title.textContent = 'Error: ' + err.message;
                    document.querySelectorAll('.btn-publish-draft').forEach(function(b) { b.disabled = false; });
                });
        }, 400);
    }

    function setBar(bar, pct) {
        bar.style.width = pct + '%';
        bar.textContent = pct + '%';
    }

    function setStep(id, state, text) {
        var el = document.getElementById(id);
        if (!el) return;
        if (state === 'running') {
            el.className = 'text-primary small fw-bold';
            el.textContent = '⏳ ' + text;
        } else if (state === 'done') {
            el.className = 'text-success small';
            el.textContent = '✅ ' + text;
        } else if (state === 'warn') {
            el.className = 'text-warning small';
            el.textContent = '⚠️ ' + text;
        }
    }
</script>
}
