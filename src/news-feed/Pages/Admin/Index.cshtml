@page
@model FxWebNews.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Newsroom";
    var drafts = Model.News.Where(n => !n.IsPublished).ToList();
    var published = Model.News.Where(n => n.IsPublished).ToList();
}

<div class="container-fluid px-4 py-3">

    <!-- Page header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fxn-page-title mb-0">Newsroom</h2>
            <small class="text-muted">Create, manage and publish articles to the FX news feed</small>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn fxn-btn-create" data-bs-toggle="modal" data-bs-target="#newArticleModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
                </svg>
                New Article
            </button>
            <a href="/Admin/BatchPublish" class="btn fxn-btn-secondary">Batch Publish to Fabric</a>
            <a href="/" class="btn fxn-btn-secondary">← Live Feed</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-@(Model.MessageType ?? "success") alert-dismissible fade show" role="alert">
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Article tables -->

            <!-- Drafts -->
            <div class="fxn-table-card mb-4">
                <div class="fxn-table-header d-flex align-items-center justify-content-between px-4 py-3">
                    <span class="fxn-table-title">Drafts <span class="fxn-counter">@drafts.Count</span></span>
                </div>
                <div class="table-responsive">
                    <table class="table fxn-table mb-0">
                        <thead>
                            <tr>
                                <th>Headline</th>
                                <th>Cat.</th>
                                <th>Sentiment</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (drafts.Any())
                            {
                                foreach (var a in drafts)
                                {
                                    <tr>
                                        <td class="fxn-td-headline">@a.Title</td>
                                        <td><span class="fxn-category-badge">@a.Category</span></td>
                                        <td>
                                            <span class="badge @(a.Type == "Good" ? "fxn-badge-bull" : "fxn-badge-bear")">
                                                @(a.Type == "Good" ? "▲" : "▼")
                                            </span>
                                        </td>
                                        <td class="fxn-td-date">@a.PublishedDate.ToString("dd MMM, HH:mm")</td>
                                        <td class="text-end">
                                            <a href="/Admin/Publish/@a.Id" class="btn btn-sm fxn-btn-review me-1">Review &amp; Publish</a>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@a.Id" style="display:inline">
                                                <button type="submit" class="btn btn-sm fxn-btn-delete"
                                                        onclick="return confirm('Delete this draft?')">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3">No drafts</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Published -->
            <div class="fxn-table-card">
                <div class="fxn-table-header d-flex align-items-center justify-content-between px-4 py-3">
                    <span class="fxn-table-title">Published <span class="fxn-counter fxn-counter-live">@published.Count</span></span>
                </div>
                <div class="table-responsive">
                    <table class="table fxn-table mb-0">
                        <thead>
                            <tr>
                                <th>Headline</th>
                                <th>Cat.</th>
                                <th>Sentiment</th>
                                <th>Published</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (published.Any())
                            {
                                foreach (var a in published)
                                {
                                    <tr>
                                        <td class="fxn-td-headline">@a.Title</td>
                                        <td><span class="fxn-category-badge">@a.Category</span></td>
                                        <td>
                                            <span class="badge @(a.Type == "Good" ? "fxn-badge-bull" : "fxn-badge-bear")">
                                                @(a.Type == "Good" ? "▲" : "▼")
                                            </span>
                                        </td>
                                        <td class="fxn-td-date">@(a.PublishedAt?.ToString("dd MMM, HH:mm") ?? "—")</td>
                                        <td class="text-end">
                                            <a href="/Admin/Publish/@a.Id" class="btn btn-sm fxn-btn-review me-1">View</a>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@a.Id" style="display:inline">
                                                <button type="submit" class="btn btn-sm fxn-btn-delete"
                                                        onclick="return confirm('Delete this article?')">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center text-muted py-3">No published articles</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        const examples = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Examples));

        function loadExample(index) {
            if (index < 0 || index >= examples.length) return;
            
            const example = examples[index];
            const form = document.getElementById('newsForm');
            
            form.querySelector('input[name="title"]').value = example.Title || '';
            form.querySelector('input[name="summary"]').value = example.Summary || '';
            form.querySelector('textarea[name="content"]').value = example.Content || '';
            form.querySelector('select[name="type"]').value = example.Type || '';
            form.querySelector('select[name="category"]').value = example.Category || '';
            form.querySelector('input[name="author"]').value = example.Author || '';
            
            form.querySelector('input[name="title"]').focus();
        }
    </script>
}

<!-- New Article Modal -->
<div class="modal fade" id="newArticleModal" tabindex="-1" aria-labelledby="newArticleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <h5 class="modal-title" id="newArticleModalLabel">New Article</h5>
                    @if (Model.Examples.Any())
                    {
                        <div class="dropdown me-2">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="examplesDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Use example">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-lightning-fill me-1" viewBox="0 0 16 16">
                                    <path d="M5.52.359A.5.5 0 0 1 6 0h4a.5.5 0 0 1 .474.658L8.694 6H12.5a.5.5 0 0 1 .395.807l-7 9a.5.5 0 0 1-.873-.454L6.823 9.5H3.5a.5.5 0 0 1-.48-.641z"/>
                                </svg>
                                Load Example
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="examplesDropdown">
                                <li><h6 class="dropdown-header">Choose a template</h6></li>
                                @for (int i = 0; i < Model.Examples.Count; i++)
                                {
                                    var example = Model.Examples[i];
                                    <li>
                                        <a class="dropdown-item" href="#" onclick="loadExample(@i); return false;">
                                            <small class="text-muted d-block">@example.Category • @(example.Type == "Good" ? "▲" : "▼")</small>
                                            <strong>@example.Title</strong>
                                        </a>
                                    </li>
                                    @if (i < Model.Examples.Count - 1)
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                }
                            </ul>
                        </div>
                    }
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" id="newsForm">
                    <div class="mb-3">
                        <label class="fxn-label">Headline *</label>
                        <input type="text" class="form-control fxn-input" name="title" placeholder="e.g. EUR/USD surges on ECB surprise" required>
                    </div>
                    <div class="mb-3">
                        <label class="fxn-label">Summary</label>
                        <input type="text" class="form-control fxn-input" name="summary" placeholder="One-line teaser shown on the feed">
                    </div>
                    <div class="mb-3">
                        <label class="fxn-label">Body *</label>
                        <textarea class="form-control fxn-input" name="content" rows="8" placeholder="Full article body…" required></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="fxn-label">Sentiment</label>
                            <select class="form-select fxn-input" name="type" required>
                                <option value="" selected disabled>Choose sentiment...</option>
                                <option value="Good">▲ Bullish</option>
                                <option value="Bad">▼ Bearish</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="fxn-label">Category</label>
                            <select class="form-select fxn-input" name="category">
                                <option value="" selected disabled>Choose category...</option>
                                <option value="FX">FX</option>
                                <option value="Equities">Equities</option>
                                <option value="Commodities">Commodities</option>
                                <option value="Crypto">Crypto</option>
                                <option value="Rates">Rates</option>
                                <option value="Macro">Macro</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="fxn-label">Author</label>
                        <input type="text" class="form-control fxn-input" name="author" placeholder="FX News Team">
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn fxn-btn-create">Save as Draft</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>