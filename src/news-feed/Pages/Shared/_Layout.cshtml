<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FX News Centre</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FxWebNews.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Top bar: brand + market data strip -->
        <div class="fxn-topbar">
            <div class="container-fluid px-4 d-flex align-items-center justify-content-between">
                <a class="fxn-brand" asp-area="" asp-page="/Index">
                    <span class="fxn-brand-fx">FX</span><span class="fxn-brand-news">News Centre</span>
                </a>
                @if (ViewData["TickerHeadlines"] is List<string> headlines && headlines.Any())
                {
                    <div class="fxn-topbar-ticker d-none d-md-flex">
                        <span class="fxn-ticker-label">LIVE</span>
                        <div class="fxn-ticker-track">
                            <span class="fxn-ticker-items">
                                @foreach (var h in headlines)
                                {
                                    <span class="fxn-ticker-item">@h &nbsp;&nbsp;&nbsp;</span>
                                }
                            </span>
                        </div>
                    </div>
                }
                <nav class="fxn-nav d-flex gap-3 align-items-center">
                    <a class="fxn-nav-link" href="/Admin">Newsroom</a>
                </nav>
            </div>
        </div>
        <!-- Category nav bar -->
        <div class="fxn-catbar">
            <div class="container-fluid px-4">
                <a class="fxn-catbar-item @(ViewData["ActiveSource"] as string == "morningstar" ? "active" : "")" href="/?source=morningstar">Morningstar</a>
                <a class="fxn-catbar-item @(ViewData["ActiveSource"] as string == "bloomberg" ? "active" : "")" href="/?source=bloomberg">Bloomberg Terminal</a>
            </div>
        </div>
    </header>

    <main role="main" class="pb-4">
        @RenderBody()
    </main>

    <footer class="fxn-footer">
        <div class="container-fluid px-4 d-flex flex-wrap justify-content-between align-items-center">
            <span>&copy; 2026 FX News Centre — For informational purposes only. Not financial advice.</span>
            <a class="fxn-footer-link" asp-area="" asp-page="/Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>