<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FX News Centre</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FxWebNews.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Top bar: brand + market data strip -->
        <div class="fxn-topbar">
            <div class="container-fluid px-4 d-flex align-items-center justify-content-between">
                <a class="fxn-brand" asp-area="" asp-page="/Index">
                    <span class="fxn-brand-fx">FX</span><span class="fxn-brand-news">News Centre</span>
                </a>
                <div class="fxn-market-strip d-none d-md-flex gap-4">
                    <span class="fxn-market-pair"><span class="fxn-pair-label">EUR/USD</span> <span class="fxn-tick-bull">1.0842 ▲</span></span>
                    <span class="fxn-market-pair"><span class="fxn-pair-label">GBP/USD</span> <span class="fxn-tick-bull">1.2731 ▲</span></span>
                    <span class="fxn-market-pair"><span class="fxn-pair-label">USD/JPY</span> <span class="fxn-tick-bear">148.23 ▼</span></span>
                    <span class="fxn-market-pair"><span class="fxn-pair-label">AUD/USD</span> <span class="fxn-tick-bear">0.6512 ▼</span></span>
                    <span class="fxn-market-pair"><span class="fxn-pair-label">XAU/USD</span> <span class="fxn-tick-bull">2341.50 ▲</span></span>
                </div>
                <nav class="fxn-nav d-flex gap-3 align-items-center">
                    <a class="fxn-nav-link @(ViewData["ActiveSource"] as string == "" || ViewData["ActiveSource"] == null ? "active" : "")" asp-area="" asp-page="/Index">Markets</a>
                    <a class="fxn-nav-link fxn-nav-morningstar @(ViewData["ActiveSource"] as string == "morningstar" ? "active" : "")" asp-area="" asp-page="/Index" asp-route-source="morningstar">Morningstar</a>
                    <a class="fxn-nav-link fxn-nav-bloomberg @(ViewData["ActiveSource"] as string == "bloomberg" ? "active" : "")" asp-area="" asp-page="/Index" asp-route-source="bloomberg">Bloomberg Terminal</a>
                    <a class="fxn-nav-link" href="/Admin">Newsroom</a>
                </nav>
            </div>
        </div>
        <!-- Category nav bar -->
        <div class="fxn-catbar">
            <div class="container-fluid px-4">
                <span class="fxn-catbar-item active">All</span>
                <span class="fxn-catbar-item">FX</span>
                <span class="fxn-catbar-item">Equities</span>
                <span class="fxn-catbar-item">Commodities</span>
                <span class="fxn-catbar-item">Crypto</span>
                <span class="fxn-catbar-item">Rates</span>
                <span class="fxn-catbar-item">Macro</span>
            </div>
        </div>
    </header>

    <main role="main" class="pb-4">
        @RenderBody()
    </main>

    <footer class="fxn-footer">
        <div class="container-fluid px-4 d-flex flex-wrap justify-content-between align-items-center">
            <span>&copy; 2026 FX News Centre — For informational purposes only. Not financial advice.</span>
            <a class="fxn-footer-link" asp-area="" asp-page="/Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>